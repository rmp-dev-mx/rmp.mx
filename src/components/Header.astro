---
import LogoMarca from "@components/LogoMarca.astro";
import { url } from "../lib/url";

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/servicios", label: "Servicios" },
  { href: "/boletin", label: "Boletín" },
  { href: "/talento", label: "Talento" },
  { href: "/contacto", label: "Contacto" },
];

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  const completo = url(href);
  if (href === "/") return pathname === completo || pathname === `${completo}/`;
  return pathname.startsWith(completo);
}
---

<header class="site-header" id="site-header">
  <div class="header-inner">

    <a href={url("/")} class="logo" aria-label="Ramírez Medellín, S.C. — ir al inicio">
      <LogoMarca class="logo-svg" />
      <span class="logo-texto">
        <span class="logo-firma">Ramírez Medellín</span>
        <span class="logo-sc">S.C.</span>
      </span>
    </a>

    <nav aria-label="Navegación principal">
      <ul class="nav-menu" id="nav-menu" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={url(href)}
              class:list={["nav-link", { "nav-link--activo": isActive(href) }]}
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="nav-toggle"
      id="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Abrir menú de navegación"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

  </div>
</header>

<style>
  /* ── Variables de estado del header ── */
  .site-header {
    --h-bg: var(--papel);
    --h-color: var(--tinta);
    --h-border: var(--regla);
  }
  .site-header.scrolled {
    --h-bg: var(--tinta);
    --h-color: var(--papel);
    --h-border: transparent;
    --oro: var(--oro-claro); /* contraste AA del oro sobre tinta */
    --oro-contraste: var(--tinta);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--h-bg);
    color: var(--h-color);
    border-bottom: 1px solid var(--h-border);
    transition: background 0.35s ease, color 0.35s ease, border-color 0.35s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header { transition: none; }
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: calc(var(--espacio) * 3);
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding: 0 calc(var(--espacio) * 3);
    height: 64px;
  }

  /* ── Logo ── */
  .logo {
    display: flex;
    align-items: center;
    gap: calc(var(--espacio) * 1.5);
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .logo-svg {
    height: 38px;
    flex-shrink: 0;
  }

  .logo-texto {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .logo-firma {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.01em;
  }

  .logo-sc {
    font-family: var(--fuente-datos);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--oro);
    text-transform: uppercase;
  }

  /* ── Nav ── */
  nav { flex: 1; }

  .nav-menu {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
    list-style: none;
  }

  .nav-link {
    display: block;
    padding: 6px calc(var(--espacio) * 1.25);
    font-family: var(--fuente-texto);
    font-size: 17px;
    font-weight: 500;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radio);
    transition: color 0.15s ease;
  }

  .nav-link:hover,
  .nav-link--activo {
    color: var(--oro);
  }

  .nav-link--activo { font-weight: 700; }

  /* ── Hamburguesa ── */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    padding: 10px;
    min-width: 44px;
    min-height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    border-radius: var(--radio);
    flex-shrink: 0;
  }

  .hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-bar { transition: none; }
  }

  .nav-toggle[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-toggle[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Tablet ── */
  @media (min-width: 768px) and (max-width: 1023px) {
    .header-inner { gap: calc(var(--espacio) * 2); }
    .logo-texto { display: none; }
    .nav-link { font-size: 15px; padding: 6px calc(var(--espacio) * 0.75); }
  }

  /* ── Móvil ── */
  @media (max-width: 767px) {
    .header-inner {
      height: 56px;
      padding: 0 calc(var(--espacio) * 2);
      position: relative;
    }

    nav {
      position: absolute;
      top: 56px;
      left: 0;
      right: 0;
      background: var(--h-bg);
      border-bottom: 1px solid var(--h-border);
      transition: background 0.35s ease, border-color 0.35s ease;
    }

    @media (prefers-reduced-motion: reduce) {
      nav { transition: none; }
    }

    .nav-menu {
      display: none;
      flex-direction: column;
      align-items: stretch;
      padding: var(--espacio) calc(var(--espacio) * 2) calc(var(--espacio) * 2);
      gap: 2px;
    }

    .nav-menu.nav-menu--open { display: flex; }

    .nav-link { font-size: 17px; padding: 10px calc(var(--espacio) * 1.5); }

    .nav-toggle { display: flex; margin-left: auto; }
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  function actualizarHeader() {
    header?.classList.toggle("scrolled", window.scrollY > 60);
  }
  window.addEventListener("scroll", actualizarHeader, { passive: true });
  actualizarHeader();

  toggle?.addEventListener("click", () => {
    const abierto = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!abierto));
    menu?.classList.toggle("nav-menu--open", !abierto);
  });
</script>
