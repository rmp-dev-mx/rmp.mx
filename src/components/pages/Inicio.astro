---
import Base from "@layouts/Base.astro";
import { url } from "../../lib/url";
import Boton from "@components/Boton.astro";
import { getLang, localizedUrl } from "../../i18n/utils";
import { getHome } from "../../i18n/home";

const lang = getLang(Astro.currentLocale);
const h = getHome(lang);

const servicios = h.servicios;
const stats = h.stats;
const marquee = h.marquee;
---

<Base title={h.metaTitle} description={h.metaDesc} translated={true}>

  <!-- ═══════════════════════════════════════════ HERO ═══ -->
  <section class="hero fondo-oscuro">

    <!-- Rayado del libro mayor -->
    <div class="hero-lineas" aria-hidden="true"></div>
    <!-- Columna de margen contable (línea vertical roja clásica de libreta) -->
    <div class="hero-margen" aria-hidden="true"></div>

    <div class="hero-inner">

      <!-- Texto -->
      <div class="hero-texto">
        <p class="hero-eyebrow">
          <span class="hero-eyebrow-linea" aria-hidden="true"></span>
          {h.heroEyebrow}
        </p>

        <h1 class="hero-h1" aria-label={h.heroAria}>
          {h.heroH1.map((w) => (
            <Fragment>
              <span class:list={["hero-palabra", { "hero-palabra--oro": w.oro }]}><span>{w.t}</span></span>
              {w.br ? <br /> : " "}
            </Fragment>
          ))}
        </h1>

        <p class="hero-sub">{h.heroSub}</p>

        <div class="hero-ctas">
          <Boton href={localizedUrl("/contacto", lang)} variant="primario">{h.heroCta}</Boton>
        </div>
      </div>

      <!-- Emblema: 28 monumental + anillos trazándose + medias lunas -->
      <div class="hero-emblema" id="hero-emblema" aria-hidden="true">
        <svg class="emblema-anillos" viewBox="0 0 480 480" fill="none">
          <circle class="anillo anillo-1" cx="240" cy="240" r="206" />
          <circle class="anillo anillo-2" cx="240" cy="240" r="196" />
          <circle class="anillo anillo-3" cx="240" cy="240" r="148" />
        </svg>
        <img class="emblema-marca" src={url("/images/logo-rmp-emblema.webp")} alt="" width="560" height="560" decoding="async" />
        <div class="emblema-centro">
          <span class="emblema-num" id="emblema-num" data-fin="28">00</span>
          <span class="emblema-label">{h.emblemaAnios}</span>
        </div>
        <span class="emblema-sello emblema-sello--top">EST. 1998</span>
        <span class="emblema-sello emblema-sello--bottom">S.L.P. · MÉXICO</span>
      </div>

    </div>

    <!-- Ticker contable -->
    <div class="ticker" aria-hidden="true">
      <div class="ticker-pista">
        {[0, 1].map(() => (
          <div class="ticker-grupo">
            {marquee.map((item) => (
              <span class="ticker-item">
                {item}
                <span class="ticker-sep">·</span>
              </span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ STATS ═══ -->
  <section class="stats fondo-oscuro revela" aria-label="Cifras de la firma">
    <div class="contenedor">
      <div class="doble-linea" aria-hidden="true"></div>
      <ul class="stats-lista" role="list">
        {stats.map(({ num, label }) => (
          <li class="stats-item">
            <span class="stats-cifra" data-contar={String(num)}>0</span>
            <span class="stats-label">{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ════════════════════════════════════ SERVICIOS ═══ -->
  <section class="servicios" aria-labelledby="servicios-titulo">
    <div class="contenedor">
      <header class="servicios-header revela">
        <div>
          <p class="eyebrow">{h.serviciosEyebrow}</p>
          <h2 id="servicios-titulo">{h.serviciosTitulo[0]}<br />{h.serviciosTitulo[1]}</h2>
        </div>
        <p class="servicios-header-desc">{h.serviciosDesc}</p>
      </header>

      <ul class="servicios-grid" role="list">
        {servicios.map(({ folio, titulo, id, desc }, i) => (
          <li class="revela" style={`--retraso: ${i * 90}ms`}>
            <article class="servicio-card">
              <span class="servicio-folio" aria-hidden="true">{folio}</span>
              <div class="servicio-cuerpo">
                <h3 class="servicio-titulo">{titulo}</h3>
                <p class="servicio-desc">{desc}</p>
              </div>
              <a
                href={localizedUrl(`/servicios#${id}`, lang)}
                class="servicio-link"
                aria-label={h.verServiciosDe(titulo)}
              >
                <span>{h.verDetalle}</span>
                <span class="servicio-link-arrow" aria-hidden="true">→</span>
              </a>
            </article>
          </li>
        ))}
      </ul>

      <div class="servicios-pie revela">
        <Boton href={localizedUrl("/servicios", lang)} variant="secundario">{h.todosServicios}</Boton>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ BOLETÍN ═══ -->
  <section class="boletin fondo-oscuro" aria-labelledby="boletin-titulo">
    <div class="contenedor">
      <div class="boletin-grid">
        <div class="revela">
          <p class="eyebrow">{h.boletinEyebrow}</p>
          <h2 id="boletin-titulo" class="boletin-titulo">
            {h.boletinTitulo[0]}<br />{h.boletinTitulo[1]}
          </h2>
          <p class="boletin-desc">{h.boletinDesc}</p>
          <div class="boletin-ctas">
            <Boton href={localizedUrl("/boletin", lang)} variant="primario">{h.boletinPublicacion}</Boton>
            <Boton href={localizedUrl("/boletin", lang)} variant="secundario">{h.boletinHistorial}</Boton>
          </div>
        </div>
        <div class="boletin-deco revela" aria-hidden="true">
          <span class="boletin-deco-num">2026</span>
          <span class="boletin-deco-mes">{h.boletinMes}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════ FILOSOFÍA ═══ -->
  <section class="filosofia" aria-label="Filosofía de la firma">
    <div class="contenedor">
      <div class="filosofia-inner revela">
        <span class="filosofia-comilla" aria-hidden="true">❝</span>
        <blockquote class="filosofia-cita">{h.filosofiaCita}</blockquote>
      </div>
      <div class="filosofia-pie revela">
        <p class="filosofia-firma">{h.filosofiaFirma}</p>
        <Boton href={localizedUrl("/nosotros", lang)} variant="secundario">{h.filosofiaCta}</Boton>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ CTA CONTACTO ═══ -->
  <section class="cta fondo-oscuro" aria-label="Contacto">
    <img
      class="cta-fondo"
      src={url("/images/fotos/inicio-escritorio.webp")}
      alt=""
      width="2400"
      height="1600"
      loading="lazy"
      decoding="async"
    />
    <div class="cta-velo" aria-hidden="true"></div>
    <div class="contenedor">
      <div class="doble-linea" aria-hidden="true"></div>
      <div class="cta-inner revela">
        <div>
          <p class="eyebrow">{h.ctaEyebrow}</p>
          <h2 class="cta-titulo">{h.ctaTitulo[0]}<br />{h.ctaTitulo[1]}</h2>
          <address class="cta-datos">
            <a href="tel:+524448334098">444-833-40-98</a>
            <span aria-hidden="true">·</span>
            <a href="tel:+524448334099">444-833-40-99</a>
            <br />
            <a href="mailto:despacho@rmp.mx">despacho@rmp.mx</a>
          </address>
        </div>
        <div class="cta-accion">
          <Boton href={localizedUrl("/contacto", lang)} variant="primario">{h.ctaAgenda}</Boton>
          <p class="cta-direccion">
            Calle Francisco Peña 245<br />Las Águilas 3ra Sección<br />
            San Luis Potosí, S.L.P.
          </p>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════ Utilidades ═══════ */
  .contenedor {
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding-inline: calc(var(--espacio) * 3);
  }

  .eyebrow {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2.5);
  }

  .doble-linea {
    border-top: 1px solid var(--oro);
    position: relative;
    margin-bottom: calc(var(--espacio) * 7);
  }
  .doble-linea::after {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--oro);
  }

  /* ═══════ Imagen de fondo del CTA + velo ═══════ */
  .cta-fondo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    z-index: 0;
  }
  .cta-velo {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      105deg,
      var(--tinta) 0%,
      rgb(22 36 58 / 0.93) 40%,
      rgb(22 36 58 / 0.74) 100%
    );
  }


  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    background-color: var(--tinta);
    background-image: radial-gradient(
      ellipse 90% 70% at 70% 20%,
      rgb(26 53 101 / 0.55),
      transparent 60%
    );
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Rayado horizontal */
  .hero-lineas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 47px,
      rgb(216 210 196 / 0.08) 47px,
      rgb(216 210 196 / 0.08) 48px
    );
    mask-image: linear-gradient(to bottom, transparent, black 18%);
    animation: lineas-in 1.4s ease both;
  }

  /* Margen contable vertical */
  .hero-margen {
    position: absolute;
    top: 0;
    bottom: 0;
    left: clamp(24px, 6vw, 96px);
    width: 1px;
    background: rgb(168 123 45 / 0.35);
    pointer-events: none;
    transform-origin: top;
    animation: margen-in 1s ease 0.3s both;
  }

  @keyframes lineas-in { from { opacity: 0; } to { opacity: 1; } }
  @keyframes margen-in { from { transform: scaleY(0); } to { transform: scaleY(1); } }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    align-items: center;
    gap: calc(var(--espacio) * 6);
    width: 100%;
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding: calc(64px + var(--espacio) * 6) calc(var(--espacio) * 3) calc(var(--espacio) * 6);
    flex: 1;
  }

  /* ── Texto ── */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: calc(var(--espacio) * 1.5);
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 4);
    animation: sube 0.5s ease 0.2s both;
  }

  .hero-eyebrow-linea {
    width: 48px;
    height: 1px;
    background: var(--oro);
    flex-shrink: 0;
  }

  .hero-h1 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(56px, 8vw, 124px);
    line-height: 0.98;
    letter-spacing: -0.025em;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 4);
  }

  /* Reveal palabra por palabra con clip */
  .hero-palabra {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
  }

  .hero-palabra > span {
    display: inline-block;
    transform: translateY(110%);
    animation: palabra-sube 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-palabra:nth-child(1) > span { animation-delay: 0.30s; }
  .hero-palabra:nth-child(2) > span { animation-delay: 0.42s; }
  .hero-palabra--oro > span { animation-delay: 0.54s; }

  .hero-palabra--oro > span {
    color: var(--oro);
    font-style: italic;
  }

  @keyframes palabra-sube {
    from { transform: translateY(110%); }
    to   { transform: translateY(0); }
  }

  .hero-sub {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.7;
    color: rgb(250 247 240 / 0.6);
    max-width: 440px;
    margin-bottom: calc(var(--espacio) * 5);
    animation: sube 0.6s ease 0.7s both;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 3);
    animation: sube 0.6s ease 0.85s both;
  }

  @keyframes sube {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Emblema ── */
  .hero-emblema {
    position: relative;
    aspect-ratio: 1;
    max-width: 480px;
    width: 100%;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
  }

  .emblema-anillos {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .anillo {
    stroke: var(--oro);
    stroke-width: 1;
    stroke-dasharray: 1300;
    stroke-dashoffset: 1300;
    animation: traza 1.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .anillo-1 { animation-delay: 0.5s; opacity: 0.9; }
  .anillo-2 { animation-delay: 0.65s; opacity: 0.5; }
  .anillo-3 {
    animation-delay: 0.9s;
    opacity: 0.25;
    stroke: var(--papel);
    stroke-dasharray: 930;
    stroke-dashoffset: 930;
  }

  @keyframes traza { to { stroke-dashoffset: 0; } }

  .emblema-marca {
    position: absolute;
    width: 58%;
    height: auto;
    opacity: 0.1;
    animation: marca-gira 90s linear infinite;
  }

  @keyframes marca-gira {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .emblema-centro {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: calc(var(--espacio) * 0.5);
    animation: aparece 0.8s ease 1.1s both;
  }

  @keyframes aparece { from { opacity: 0; } to { opacity: 1; } }

  .emblema-num {
    font-family: var(--fuente-datos);
    font-size: clamp(96px, 12vw, 160px);
    font-weight: 500;
    line-height: 0.9;
    color: var(--papel);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.04em;
  }

  .emblema-label {
    font-family: var(--fuente-datos);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    text-indent: 0.5em;
    color: var(--oro);
  }

  .emblema-sello {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--fuente-datos);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    color: rgb(250 247 240 / 0.35);
    white-space: nowrap;
    animation: aparece 0.8s ease 1.3s both;
  }

  .emblema-sello--top { top: 8%; }
  .emblema-sello--bottom { bottom: 8%; }

  /* ── Ticker ── */
  .ticker {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgb(216 210 196 / 0.14);
    overflow: hidden;
    padding-block: calc(var(--espacio) * 2);
    background: rgb(0 0 0 / 0.18);
    backdrop-filter: blur(2px);
  }

  .ticker::before {
    content: "";
    position: absolute;
    top: 3px;
    left: 0;
    right: 0;
    border-top: 1px solid rgb(216 210 196 / 0.07);
  }

  .ticker-pista {
    display: flex;
    width: max-content;
    animation: ticker-mueve 36s linear infinite;
  }

  .ticker:hover .ticker-pista { animation-play-state: paused; }

  .ticker-grupo {
    display: flex;
    flex-shrink: 0;
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(250 247 240 / 0.45);
    white-space: nowrap;
  }

  .ticker-sep {
    color: var(--oro);
    margin-inline: calc(var(--espacio) * 3);
  }

  @keyframes ticker-mueve {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Reduced motion: hero completo ── */
  @media (prefers-reduced-motion: reduce) {
    .hero-lineas,
    .hero-margen,
    .hero-eyebrow,
    .hero-sub,
    .hero-ctas,
    .emblema-centro,
    .emblema-sello { animation: none; }

    .hero-palabra > span { animation: none; transform: none; }

    .anillo { animation: none; stroke-dashoffset: 0; }

    .emblema-marca { animation: none; }

    .ticker-pista { animation: none; }
  }

  /* ═══════ STATS ═══════ */
  .stats {
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 10);
  }

  .stats-lista {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    list-style: none;
  }

  .stats-item {
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 1.25);
    padding: calc(var(--espacio) * 3) calc(var(--espacio) * 4);
    border-inline-start: 1px solid rgb(216 210 196 / 0.12);
  }

  .stats-item:first-child { border-inline-start: none; padding-inline-start: 0; }

  .stats-cifra {
    font-family: var(--fuente-datos);
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 500;
    color: var(--papel);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stats-label {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(250 247 240 / 0.65); /* AA sobre tinta */
  }

  /* ═══════ SERVICIOS ═══════ */
  .servicios { padding-block: calc(var(--espacio) * 14); }

  .servicios-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(var(--espacio) * 6);
    align-items: end;
    margin-bottom: calc(var(--espacio) * 8);
    padding-bottom: calc(var(--espacio) * 6);
    border-bottom: 1px solid var(--regla);
  }

  .servicios-header h2 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--tinta);
    margin: 0;
  }

  .servicios-header-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--pizarra);
    max-width: 420px;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--regla);
    list-style: none;
    margin-bottom: calc(var(--espacio) * 8);
  }

  .servicio-card {
    background: var(--papel);
    padding: calc(var(--espacio) * 5);
    display: flex;
    flex-direction: column;
    min-height: 340px;
    height: 100%;
    position: relative;
    transition: background 0.35s ease;
  }

  .servicio-card:hover { background: var(--tinta); }

  .servicio-folio {
    font-family: var(--fuente-datos);
    font-size: clamp(56px, 7vw, 80px);
    font-weight: 500;
    line-height: 1;
    color: var(--regla);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
    transition: color 0.35s ease;
  }

  .servicio-card:hover .servicio-folio { color: rgb(250 247 240 / 0.07); }

  .servicio-cuerpo {
    margin-top: auto;
    padding-top: calc(var(--espacio) * 3);
  }

  .servicio-titulo {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 24px;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 1.5);
    transition: color 0.35s ease;
  }

  .servicio-card:hover .servicio-titulo { color: var(--papel); }

  .servicio-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--pizarra);
    margin: 0 0 calc(var(--espacio) * 3);
    transition: color 0.35s ease;
  }

  .servicio-card:hover .servicio-desc { color: rgb(250 247 240 / 0.55); }

  .servicio-link {
    display: inline-flex;
    align-items: center;
    gap: var(--espacio);
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oro);
    text-decoration: none;
    align-self: flex-start;
  }

  .servicio-link-arrow { transition: transform 0.2s ease; }
  .servicio-link:hover .servicio-link-arrow { transform: translateX(4px); }

  @media (prefers-reduced-motion: reduce) {
    .servicio-card,
    .servicio-folio,
    .servicio-titulo,
    .servicio-desc,
    .servicio-link-arrow { transition: none; }
  }

  .servicios-pie { text-align: center; }

  /* ═══════ BOLETÍN ═══════ */
  .boletin {
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 14);
    overflow: hidden;
  }

  .boletin-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: calc(var(--espacio) * 6);
    align-items: center;
  }

  .boletin-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--papel);
    margin-block: calc(var(--espacio) * 2) calc(var(--espacio) * 3);
  }

  .boletin-desc {
    font-size: 15px;
    line-height: 1.75;
    color: rgb(250 247 240 / 0.6);
    margin-bottom: calc(var(--espacio) * 5);
    max-width: 520px;
  }

  .boletin-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 1.5);
  }

  .boletin-deco {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    opacity: 0.07;
    user-select: none;
    pointer-events: none;
  }

  .boletin-deco-num {
    font-family: var(--fuente-datos);
    font-size: clamp(72px, 10vw, 120px);
    font-weight: 500;
    color: var(--papel);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .boletin-deco-mes {
    font-family: var(--fuente-datos);
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--papel);
  }

  /* ═══════ FILOSOFÍA ═══════ */
  .filosofia { padding-block: calc(var(--espacio) * 14); }

  .filosofia-inner {
    position: relative;
    padding-block: calc(var(--espacio) * 6);
    border-top: 1px solid var(--regla);
    border-bottom: 1px solid var(--regla);
    margin-bottom: calc(var(--espacio) * 6);
  }

  .filosofia-inner::before {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--regla);
  }
  .filosofia-inner::after {
    content: "";
    position: absolute;
    inset: auto 0 -4px 0;
    border-bottom: 1px solid var(--regla);
  }

  .filosofia-comilla {
    display: block;
    font-family: var(--fuente-display);
    font-size: clamp(56px, 8vw, 96px);
    line-height: 0.8;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 3);
    user-select: none;
  }

  .filosofia-cita {
    font-family: var(--fuente-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(20px, 2.8vw, 34px);
    line-height: 1.5;
    color: var(--tinta);
    max-width: 900px;
    margin: 0;
  }

  .filosofia-pie {
    display: flex;
    align-items: center;
    justify-content: space-between;
