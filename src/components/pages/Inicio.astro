  .filosofia-firma {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pizarra);
  }

  /* ═══════ CTA ═══════ */
  .cta {
    position: relative;
    overflow: hidden;
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 10) calc(var(--espacio) * 14);
  }
  .cta .contenedor {
    position: relative;
    z-index: 1;
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: calc(var(--espacio) * 8);
    align-items: start;
  }

  .cta-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--papel);
    margin-block: calc(var(--espacio) * 2) calc(var(--espacio) * 3);
  }

  .cta-datos {
    font-style: normal;
