    text-align: right;
  }

  /* ═══════ Responsive ═══════ */
  @media (max-width: 1023px) {
    /* En pantallas angostas el hero fluye con su contenido; 100dvh
       provocaba que el emblema desbordara sobre el ticker */
    .hero { min-height: auto; }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: calc(var(--espacio) * 8);
      padding-block: calc(56px + var(--espacio) * 8) calc(var(--espacio) * 8);
    }

    .hero-emblema { max-width: 340px; }

    .stats-lista { grid-template-columns: repeat(2, 1fr); }
    .stats-item:nth-child(3) { border-inline-start: none; padding-inline-start: 0; }

    .servicios-header { grid-template-columns: 1fr; }
  }

  @media (max-width: 767px) {
    .contenedor { padding-inline: calc(var(--espacio) * 2); }

    .hero-h1 { font-size: clamp(48px, 13vw, 72px); }

    .hero-emblema { max-width: 280px; }

    .emblema-num { font-size: clamp(72px, 20vw, 96px); }

    .stats-item { padding: calc(var(--espacio) * 2.5) calc(var(--espacio) * 2); }

    .servicios-grid { grid-template-columns: 1fr; }

    .servicio-card { min-height: 280px; }

    .boletin-grid { grid-template-columns: 1fr; }
    .boletin-deco { display: none; }

    .filosofia-cita { font-size: clamp(18px, 5vw, 26px); }

    .cta-inner { grid-template-columns: 1fr; }
    .cta-accion { align-items: flex-start; }
    .cta-direccion { text-align: left; }
    .filosofia-pie { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ── Contador del emblema (00 → 28) ── */
  const num = document.getElementById("emblema-num");
  if (num) {
    const fin = Number(num.dataset.fin ?? 28);
    if (reduceMotion) {
      num.textContent = String(fin);
    } else {
      const dur = 1400;
      const inicio = performance.now() + 1100; // espera a que aparezca el centro
      function tick(ahora: number) {
        const t = Math.min(Math.max((ahora - inicio) / dur, 0), 1);
        const eased = 1 - Math.pow(1 - t, 3);
        num!.textContent = String(Math.round(eased * fin)).padStart(2, "0");
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  }

  /* ── Parallax sutil del emblema con el cursor ── */
  const emblema = document.getElementById("hero-emblema");
  if (emblema && !reduceMotion && matchMedia("(pointer: fine)").matches) {
    const hero = emblema.closest(".hero");
    hero?.addEventListener("mousemove", (e) => {
      const me = e as MouseEvent;
      const { innerWidth: w, innerHeight: h } = window;
      const x = (me.clientX / w - 0.5) * 14;
      const y = (me.clientY / h - 0.5) * 14;
      emblema.style.transform = `translate(${x}px, ${y}px)`;
    });
    hero?.addEventListener("mouseleave", () => {
      emblema.style.transform = "";
    });
  }

  /* ── Reveal al scroll ── */
  const revelables = document.querySelectorAll(".revela");
  if (reduceMotion) {
    revelables.forEach((el) => el.classList.add("visible"));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
    );
    revelables.forEach((el) => io.observe(el));
  }

  /* ── Contadores de stats al entrar en viewport ── */
  const cifras = document.querySelectorAll<HTMLElement>("[data-contar]");
  if (cifras.length) {
    if (reduceMotion) {
      cifras.forEach((el) => (el.textContent = el.dataset.contar ?? ""));
    } else {
      const ioStats = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target as HTMLElement;
            ioStats.unobserve(el);
            const fin = Number(el.dataset.contar);
            const dur = 1200;
            const inicio = performance.now();
            function tick(ahora: number) {
              const t = Math.min((ahora - inicio) / dur, 1);
              const eased = 1 - Math.pow(1 - t, 3);
              el.textContent = String(Math.round(eased * fin));
              if (t < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          }
        },
        { threshold: 0.4 }
      );
      cifras.forEach((el) => ioStats.observe(el));
    }
  }
</script>
