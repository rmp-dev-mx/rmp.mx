---
import Base from "@layouts/Base.astro";
import AsistenteContacto from "@components/AsistenteContacto.astro";
import { url } from "../../lib/url";
import { getLang } from "../../i18n/utils";
import { getContacto } from "../../i18n/contacto";

const lang = getLang(Astro.currentLocale);
const c = getContacto(lang);

// TODO: el cliente desconoce cuáles de los 3 teléfonos están habilitados; confirmar.
const telefonos = [
  { num: "444-833-40-98", tel: "+524448334098" },
  { num: "444-833-40-99", tel: "+524448334099" },
  { num: "444-211-60-00", tel: "+524442116000" },
];

// Embed corregido (el original tenía la URL malformada con saltos de línea)
const mapaSrc =
  "https://www.google.com/maps?q=Calle+Francisco+Pe%C3%B1a+245,+Las+%C3%81guilas+3ra+Secci%C3%B3n,+San+Luis+Potos%C3%AD,+S.L.P.&output=embed";
---

<Base title={c.metaTitle} description={c.metaDesc} translated={true}>

  <!-- ═══════════════════════════════ HERO ═══ -->
  <section class="phero fondo-oscuro">
    <img
      class="phero-fondo"
      src={url("/images/fotos/contacto-oficina.webp")}
      alt=""
      width="2400"
      height="1600"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="phero-velo" aria-hidden="true"></div>
    <div class="phero-lineas" aria-hidden="true"></div>
    <div class="contenedor phero-inner">
      <p class="eyebrow phero-anim-1">
        <span class="eyebrow-linea" aria-hidden="true"></span>
        {c.heroEyebrow}
      </p>
      <h1 class="phero-h1 phero-anim-2">
        {c.heroH1[0]}<br />
        <em class="texto-oro">{c.heroH1[1]}</em>
      </h1>
      <p class="phero-sub phero-anim-3">{c.heroSub}</p>
    </div>
  </section>

  <!-- ═══════════════════════ FORMULARIO + DATOS ═══ -->
  <section class="contacto" aria-label={c.seccionAria}>
    <div class="contenedor">
      <div class="contacto-grid">

        <!-- Asistente de contacto guiado -->
        <div class="form-col revela">
          <AsistenteContacto asistente={c.asistente} />

          <p class="respaldo">
            {c.respaldoPre}<a href="mailto:despacho@rmp.mx">despacho@rmp.mx</a>{c.respaldoPost}
          </p>
        </div>

        <!-- Datos -->
        <aside class="datos-col revela" style="--retraso: 120ms">
          <div class="dato">
            <h3 class="dato-titulo">{c.datoOficina}</h3>
            <address class="dato-texto">
              Calle Francisco Peña 245<br />
              Las Águilas 3ra Sección<br />
              San Luis Potosí, S.L.P.
            </address>
          </div>

          <div class="dato">
            <h3 class="dato-titulo">{c.datoTelefonos}</h3>
            <ul class="dato-lista" role="list">
              {telefonos.map(({ num, tel }) => (
                <li><a href={`tel:${tel}`} class="dato-mono">{num}</a></li>
              ))}
            </ul>
          </div>

          <div class="dato">
            <h3 class="dato-titulo">{c.datoCorreo}</h3>
            <a href="mailto:despacho@rmp.mx" class="dato-mono">despacho@rmp.mx</a>
            <p class="dato-sub">{c.datoCorreoSub}</p>
            <ul class="dato-lista" role="list">
              {c.correosArea.map(({ area, correo }) => (
                <li>
                  <span class="dato-area">{area}</span>
                  <a href={`mailto:${correo}`} class="dato-mono">{correo}</a>
                </li>
              ))}
            </ul>
          </div>

          <div class="dato">
            <h3 class="dato-titulo">{c.datoHorario}</h3>
            <p class="dato-texto">
              <!-- TODO: establecer el horario de oficina con el cliente -->
              <span class="dato-pendiente">{c.datoHorarioPendiente}</span>
            </p>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ MAPA ═══ -->
  <section class="mapa revela" aria-label={c.mapaAria}>
    <iframe
      src={mapaSrc}
      title={c.mapaTitle}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </section>

</Base>

<style>
  /* ═══════ Utilidades ═══════ */
  .contenedor {
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding-inline: calc(var(--espacio) * 3);
  }

  .eyebrow {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2.5);
  }

  .eyebrow-linea {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--oro);
    vertical-align: middle;
    margin-inline-end: calc(var(--espacio) * 1.5);
  }

  .texto-oro { color: var(--oro); font-style: italic; }

  /* ═══════ Imagen de fondo del hero + velo ═══════ */
  .phero-fondo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
    z-index: 0;
  }
  .phero-velo {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      105deg,
      var(--tinta) 0%,
      rgb(22 36 58 / 0.94) 32%,
      rgb(22 36 58 / 0.78) 66%,
      rgb(22 36 58 / 0.6) 100%
    );
  }


  /* ═══════ HERO ═══════ */
  .phero {
    position: relative;
    background-color: var(--tinta);
    background-image: radial-gradient(
      ellipse 90% 70% at 30% 10%,
      rgb(26 53 101 / 0.5),
      transparent 60%
    );
    overflow: hidden;
  }

  .phero-lineas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 47px,
      rgb(216 210 196 / 0.07) 47px,
      rgb(216 210 196 / 0.07) 48px
    );
    mask-image: linear-gradient(to bottom, transparent, black 20%);
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    padding-block: calc(64px + var(--espacio) * 10) calc(var(--espacio) * 10);
  }

  .phero-h1 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(44px, 6.5vw, 92px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 3);
  }

  .phero-sub {
    font-size: clamp(16px, 1.6vw, 18px);
    line-height: 1.7;
    color: rgb(250 247 240 / 0.6);
    max-width: 520px;
  }

  .phero-anim-1 { animation: sube 0.5s ease 0.1s both; }
  .phero-anim-2 { animation: sube 0.6s ease 0.25s both; }
  .phero-anim-3 { animation: sube 0.5s ease 0.4s both; }

  @keyframes sube {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .phero-anim-1, .phero-anim-2, .phero-anim-3 { animation: none; }
  }

  /* ═══════ CONTACTO ═══════ */
  .contacto { padding-block: calc(var(--espacio) * 12); }

  .contacto-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: calc(var(--espacio) * 10);
    align-items: start;
  }

  /* ── Asistente + respaldo ── */
  .respaldo {
    font-size: 14px;
    line-height: 1.6;
    color: var(--pizarra);
    margin: calc(var(--espacio) * 3) 0 0;
  }
  .respaldo a { color: var(--oro); }

  /* ── Datos ── */
  .datos-col {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--oro);
    position: relative;
    padding-top: calc(var(--espacio) * 4);
  }

  .datos-col::before {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--oro);
  }

  .dato {
    padding-block: calc(var(--espacio) * 3);
    border-bottom: 1px solid var(--regla);
  }

  .dato:last-child { border-bottom: none; }

  .dato-titulo {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin: 0 0 calc(var(--espacio) * 1.5);
  }

  .dato-texto {
    font-style: normal;
    font-size: 16px;
    line-height: 1.7;
    color: var(--tinta);
  }

  .dato-lista {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 0.75);
  }

  .dato-mono {
    font-family: var(--fuente-datos);
    font-size: 15px;
    color: var(--tinta);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .dato-mono:hover { color: var(--oro); }

  .dato-sub {
    font-size: 13px;
    color: var(--pizarra);
    margin: calc(var(--espacio) * 2) 0 calc(var(--espacio) * 1.25);
  }

  .dato-lista li { display: flex; flex-direction: column; }

  .dato-area {
    font-family: var(--fuente-texto);
    font-size: 12px;
    font-weight: 500;
    color: var(--pizarra);
  }

  .dato-pendiente {
    font-family: var(--fuente-datos);
    font-size: 14px;
    color: var(--pizarra);
    font-style: italic;
  }

  /* ═══════ MAPA ═══════ */
  .mapa {
    border-top: 1px solid var(--regla);
    line-height: 0;
  }

  .mapa iframe {
    width: 100%;
    height: clamp(320px, 45vh, 480px);
    border: 0;
    filter: grayscale(0.85) contrast(1.04);
    transition: filter 0.4s ease;
  }

  .mapa iframe:hover { filter: none; }

  @media (prefers-reduced-motion: reduce) {
    .mapa iframe { transition: none; }
  }

  /* ═══════ Responsive ═══════ */
  @media (max-width: 1023px) {
    .contacto-grid {
      grid-template-columns: 1fr;
      gap: calc(var(--espacio) * 8);
    }
  }

  @media (max-width: 767px) {
    .contenedor { padding-inline: calc(var(--espacio) * 2); }

    .campo-fila { grid-template-columns: 1fr; gap: calc(var(--espacio) * 3); }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ── Reveals ── */
  const revelables = document.querySelectorAll(".revela");
  if (reduceMotion) {
    revelables.forEach((el) => el.classList.add("visible"));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: "0px 0px -30px 0px" }
    );
    revelables.forEach((el) => io.observe(el));
  }
</script>
