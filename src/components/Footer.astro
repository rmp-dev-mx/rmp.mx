---
const anio = new Date().getFullYear();

const paginasSitio = [
  { href: "/", label: "Inicio" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/servicios", label: "Servicios" },
  { href: "/boletin", label: "Boletín Resiliencia" },
  { href: "/talento", label: "Talento" },
  { href: "/contacto", label: "Contacto" },
];

const accesos = [
  { href: "/indicadores", label: "Indicadores fiscales" },
  { href: "/recursos", label: "Sitios de interés" },
  { href: "https://rmp.abaconsulting.mx/login", label: "Portal de clientes", externo: true },
  { href: "/boletin", label: "Boletín Resiliencia" },
];
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Columna 1: Identidad y contacto -->
    <div class="footer-col">
      <a href="/" class="footer-logo" aria-label="Ramírez Medellín, S.C. — ir al inicio">
        <span class="footer-logo-monograma" aria-hidden="true">RM</span>
        <span class="footer-logo-texto">
          <span class="footer-logo-firma">Ramírez Medellín</span>
          <span class="footer-logo-sc">S.C.</span>
        </span>
      </a>
      <p class="footer-tagline">Contadores Públicos y Abogados desde 1998</p>
      <address class="footer-contacto">
        <p>Calle Francisco Peña 245<br>Las Águilas 3ra Sección<br>San Luis Potosí, S.L.P.</p>
        <ul class="footer-telefonos" aria-label="Teléfonos">
          <li><a href="tel:+524448334098">444-833-40-98</a></li>
          <li><a href="tel:+524448334099">444-833-40-99</a></li>
          <li><a href="tel:+524442116000">444-211-60-00</a></li>
        </ul>
        <a href="mailto:despacho@rmp.mx" class="footer-email">despacho@rmp.mx</a>
      </address>
    </div>

    <!-- Columna 2: Mapa del sitio -->
    <div class="footer-col">
      <p class="footer-titulo-seccion">Sitio web</p>
      <nav aria-label="Mapa del sitio">
        <ul class="footer-links" role="list">
          {paginasSitio.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Columna 3: Accesos rápidos -->
    <div class="footer-col">
      <p class="footer-titulo-seccion">Accesos</p>
      <nav aria-label="Accesos rápidos">
        <ul class="footer-links" role="list">
          {accesos.map(({ href, label, externo }) => (
            <li>
              <a
                href={href}
                target={externo ? "_blank" : undefined}
                rel={externo ? "noopener noreferrer" : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Columna 4: Redes y afiliaciones -->
    <div class="footer-col">
      <p class="footer-titulo-seccion">Conecta</p>
      <ul class="footer-redes" role="list" aria-label="Redes sociales">
        <li>
          <a href="https://www.facebook.com/ramirezmedellinfirma" target="_blank" rel="noopener noreferrer" class="footer-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Facebook
          </a>
        </li>
        <li>
          <!-- TODO: confirmar URL de LinkedIn -->
          <a href="#" class="footer-red" aria-label="LinkedIn (próximamente)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </li>
      </ul>
      <div class="footer-afiliaciones">
        <p class="footer-titulo-seccion" style="margin-top: calc(var(--espacio) * 3)">Afiliaciones</p>
        <ul class="footer-badges" role="list">
          <li class="footer-badge">
            <!-- TODO: logo vector CONTPAQi -->
            <span class="badge-texto">CONTPAQi<br><span class="badge-sub">Distribuidor Asociado</span></span>
          </li>
          <li class="footer-badge">
            <!-- TODO: logo vector Pacioli -->
            <span class="badge-texto">Pacioli<br><span class="badge-sub">Asesores de Negocios, S.C.</span></span>
          </li>
        </ul>
      </div>
    </div>

  </div>

  <!-- Barra legal -->
  <div class="footer-legal">
    <div class="footer-legal-inner">
      <p>© {anio} Ramírez Medellín, S.C. Todos los derechos reservados.</p>
      <!-- TODO: redactar aviso de privacidad (obligatorio por LFPDPPP al tener formularios) -->
      <a href="/aviso-de-privacidad" class="footer-legal-link">Aviso de privacidad</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--tinta);
    color: var(--papel);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: calc(var(--espacio) * 5);
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding: calc(var(--espacio) * 7) calc(var(--espacio) * 3) calc(var(--espacio) * 6);
  }

  /* --- Logo en footer --- */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--espacio);
    text-decoration: none;
    color: inherit;
    margin-bottom: calc(var(--espacio) * 2);
  }

  .footer-logo-monograma {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--oro);
    color: var(--tinta);
    font-family: var(--fuente-datos);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.05em;
    border-radius: var(--radio);
    flex-shrink: 0;
  }

  .footer-logo-texto {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .footer-logo-firma {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
  }

  .footer-logo-sc {
    font-family: var(--fuente-datos);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--oro);
    text-transform: uppercase;
  }

  .footer-tagline {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 400;
    color: rgb(250 247 240 / 0.6);
    margin-bottom: calc(var(--espacio) * 2.5);
    line-height: 1.4;
  }

  /* --- Contacto --- */
  .footer-contacto {
    font-style: normal;
    font-size: 14px;
    line-height: 1.6;
    color: rgb(250 247 240 / 0.75);
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 1.5);
  }

  .footer-telefonos {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .footer-telefonos a,
  .footer-email {
    font-family: var(--fuente-datos);
    font-size: 13px;
    color: rgb(250 247 240 / 0.85);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-telefonos a:hover,
  .footer-email:hover {
    color: var(--oro);
  }

  /* --- Encabezados de sección --- */
  .footer-titulo-seccion {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2);
  }

  /* --- Listas de links --- */
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .footer-links a {
    font-size: 14px;
    color: rgb(250 247 240 / 0.75);
    text-decoration: none;
    line-height: 1.8;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--papel);
  }

  /* --- Redes sociales --- */
  .footer-redes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer-red {
    display: inline-flex;
    align-items: center;
    gap: var(--espacio);
    font-size: 14px;
    color: rgb(250 247 240 / 0.75);
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.15s ease;
  }

  .footer-red:hover {
    color: var(--oro);
  }

  /* --- Badges de afiliación --- */
  .footer-badges {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--espacio);
  }

  .footer-badge {
    padding: var(--espacio) calc(var(--espacio) * 1.5);
    border: 1px solid rgb(250 247 240 / 0.12);
    border-radius: var(--radio);
    display: inline-block;
  }

  .badge-texto {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    color: rgb(250 247 240 / 0.85);
    line-height: 1.5;
  }

  .badge-sub {
    font-size: 10px;
    font-weight: 400;
    color: rgb(250 247 240 / 0.5);
  }

  /* --- Barra legal --- */
  .footer-legal {
    border-top: 1px solid rgb(250 247 240 / 0.1);
  }

  .footer-legal-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(var(--espacio) * 2);
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding: calc(var(--espacio) * 2.5) calc(var(--espacio) * 3);
    font-family: var(--fuente-datos);
    font-size: 12px;
    color: rgb(250 247 240 / 0.45);
  }

  .footer-legal-link {
    color: rgb(250 247 240 / 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .footer-legal-link:hover {
    color: rgb(250 247 240 / 0.8);
  }

  /* --- Responsive --- */
  @media (max-width: 1023px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: calc(var(--espacio) * 5) calc(var(--espacio) * 6);
    }
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: calc(var(--espacio) * 5);
      padding: calc(var(--espacio) * 6) calc(var(--espacio) * 2.5) calc(var(--espacio) * 5);
    }

    .footer-legal-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--espacio);
      padding: calc(var(--espacio) * 2) calc(var(--espacio) * 2.5);
    }
  }
</style>
