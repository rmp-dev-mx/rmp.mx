---
const id = `lm-${Math.random().toString(36).slice(2, 9)}`;
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 100 100"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <mask id={`${id}-g`}>
      <circle cx="58" cy="52" r="32" fill="white" />
      <circle cx="34" cy="50" r="22" fill="black" />
    </mask>
    <mask id={`${id}-a`}>
      <circle cx="38" cy="48" r="38" fill="white" />
      <circle cx="68" cy="46" r="26" fill="black" />
    </mask>
  </defs>
  <rect class="lm-gris" width="100" height="100" mask={`url(#${id}-g)`} />
  <rect class="lm-azul" width="100" height="100" mask={`url(#${id}-a)`} />
</svg>

<style>
  .lm-gris { fill: var(--lm-gris, #8899A8); transition: fill 0.3s ease; }
  .lm-azul { fill: var(--lm-azul, #1A3565); transition: fill 0.3s ease; }

  @media (prefers-reduced-motion: reduce) {
    .lm-gris, .lm-azul { transition: none; }
  }
</style>
