---
// Símbolo oficial de Ramírez Medellín (swoosh azul/gris).
// Dos versiones: a color para el header claro y silueta papel para
// el header con scroll (fondo tinta). El swap lo controla Header.astro
// según la clase .scrolled. El wordmark va en texto, no en la imagen.
import { url } from "../lib/url";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<span class:list={["logo-marca", className]} aria-hidden="true">
  <img
    class="lm-color"
    src={url("/images/logo-rmp.webp")}
    alt=""
    width="156"
    height="120"
    decoding="async"
  />
  <img
    class="lm-claro"
    src={url("/images/logo-rmp-claro.webp")}
    alt=""
    width="156"
    height="120"
    decoding="async"
  />
</span>

<style>
  /* Altura definida aquí (no en el header): Astro no propaga el scope
     del padre al root del hijo, así que .logo-svg del header no alcanza
     este <span>. Solo se usa en el header, donde mide 38px. */
  .logo-marca {
    display: inline-flex;
    line-height: 0;
    height: 38px;
  }
  .logo-marca img {
    display: block;
    height: 100%;
    width: auto;
  }
  .logo-marca .lm-claro {
    display: none;
  }
  /* Header con scroll (fondo tinta): mostrar la silueta papel.
     :global porque .scrolled vive en el ancestro <header>. */
  :global(.site-header.scrolled) .logo-marca .lm-color {
    display: none;
  }
  :global(.site-header.scrolled) .logo-marca .lm-claro {
    display: block;
  }
</style>
