---
// Asistente de contacto guiado (sin IA, 100% en el navegador).
// Clasifica la necesidad del visitante por un árbol de decisión y lo
// enruta a la encargada correcta con un mailto: prellenado.
// Los textos (árbol, encargadas, plantillas) llegan localizados vía la prop
// `asistente` (ver src/i18n/contacto.ts) y se inyectan como JSON para el
// script del cliente. Los nombres y correos no se traducen.
import { getContacto } from "../i18n/contacto";

type AsistenteDic = ReturnType<typeof getContacto>["asistente"];
interface Props { asistente: AsistenteDic }
const { asistente } = Astro.props;
const encargadas = Object.values(asistente.encargadas);
---

<div class="asistente" id="asistente">
  <div class="asistente-cabecera">
    <p class="asistente-eyebrow">{asistente.eyebrow}</p>
    <h2 class="asistente-titulo">{asistente.titulo}</h2>
    <p class="asistente-intro">{asistente.intro}</p>
  </div>

  <!-- El motor renderiza aquí los pasos. aria-live anuncia cada paso. -->
  <div class="asistente-cuerpo" id="asistente-cuerpo" aria-live="polite"></div>

  <!-- Diccionario localizado para el script del cliente -->
  <script type="application/json" id="asistente-datos" set:html={JSON.stringify(asistente)}></script>

  <noscript>
    <p class="asistente-noscript">
      {asistente.noscriptPre}<a href="mailto:despacho@rmp.mx">despacho@rmp.mx</a>{asistente.noscriptPost}
      {encargadas.map((e, i) => (
        <Fragment>
          {" "}{e.area} <a href={`mailto:${e.correo}`}>{e.correo}</a>{i < encargadas.length - 1 ? "," : "."}
        </Fragment>
      ))}
    </p>
  </noscript>
</div>

<!-- is:global porque el cuerpo del asistente se genera por JS (innerHTML) y no
     recibe el atributo de scope de Astro. Todo va prefijado con #asistente
     para no filtrarse al resto del sitio. -->
<style is:global>
  #asistente {
    background: var(--blanco);
    border: 1px solid var(--regla);
    border-radius: var(--radio);
    box-shadow: var(--sombra);
    padding: calc(var(--espacio) * 4);
  }

  #asistente .asistente-eyebrow {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin: 0 0 calc(var(--espacio) * 1.5);
  }

  #asistente .asistente-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(24px, 3vw, 32px);
    letter-spacing: -0.01em;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 1.5);
  }

  #asistente .asistente-intro {
    font-size: 15px;
    line-height: 1.6;
    color: var(--pizarra);
    margin: 0 0 calc(var(--espacio) * 4);
    max-width: 46ch;
  }

  #asistente .asistente-noscript {
    font-size: 14px;
    line-height: 1.6;
    color: var(--tinta);
  }
  #asistente .asistente-noscript a { color: var(--oro); }

  /* ── Pasos ── */
  #asistente .paso-progreso {
    font-family: var(--fuente-datos);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pizarra);
    margin: 0 0 calc(var(--espacio) * 1.5);
  }

  #asistente .paso-pregunta {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(19px, 2.2vw, 24px);
    line-height: 1.25;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 3);
    outline: none;
  }

  #asistente .opciones {
    display: flex;
    flex-direction: column;
    gap: var(--espacio);
  }

  #asistente .opcion {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(var(--espacio) * 2);
    width: 100%;
    text-align: left;
    font-family: var(--fuente-texto);
    font-size: 15px;
    line-height: 1.4;
    color: var(--tinta);
    background: var(--papel);
    border: 1px solid var(--regla);
    border-radius: var(--radio);
    padding: calc(var(--espacio) * 1.75) calc(var(--espacio) * 2);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  #asistente .opcion:hover {
    border-color: var(--oro);
    background: var(--blanco);
  }

  #asistente .opcion:focus-visible {
    outline: 2px solid var(--oro);
    outline-offset: 2px;
    border-color: var(--oro);
  }

  #asistente .opcion-flecha {
    flex-shrink: 0;
    color: var(--oro);
    font-family: var(--fuente-datos);
    transition: transform 0.15s ease;
  }
  #asistente .opcion:hover .opcion-flecha { transform: translateX(3px); }

  #asistente .paso-volver {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--espacio) * 0.5);
    margin-top: calc(var(--espacio) * 3);
    background: none;
    border: none;
    padding: var(--espacio) 0;
    font-family: var(--fuente-datos);
    font-size: 13px;
    color: var(--pizarra);
    cursor: pointer;
  }
  #asistente .paso-volver:hover { color: var(--tinta); }
  #asistente .paso-volver:focus-visible { outline: 2px solid var(--oro); outline-offset: 2px; }

  /* ── Resultado ── */
  #asistente .resultado-area {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin: 0 0 calc(var(--espacio) * 1.5);
  }

  #asistente .resultado-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: 1.3;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 1.5);
    outline: none;
  }
  #asistente .resultado-titulo strong { font-weight: 600; }

  #asistente .resultado-encargada {
    font-size: 15px;
    line-height: 1.6;
    color: var(--pizarra);
    margin: 0 0 calc(var(--espacio) * 3);
  }
  #asistente .resultado-encargada .nombre { color: var(--tinta); font-weight: 500; }

  #asistente .resultado-acciones {
    display: flex;
    flex-wrap: wrap;
    gap: var(--espacio);
  }

  #asistente .accion {
    display: inline-flex;
    align-items: center;
    gap: var(--espacio);
    font-family: var(--fuente-texto);
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radio);
    padding: calc(var(--espacio) * 1.5) calc(var(--espacio) * 3);
    min-height: 44px;
    border: 1px solid transparent;
    cursor: pointer;
  }

  #asistente .accion--correo {
    background: var(--oro);
    color: var(--oro-contraste);
    border-color: var(--oro);
    transition: filter 0.15s ease;
  }
  #asistente .accion--correo:hover { filter: brightness(0.9); }
  #asistente .accion--correo:focus-visible { outline: 2px solid var(--tinta); outline-offset: 2px; }

  /* WhatsApp deshabilitado hasta tener números (TODO cliente) */
  #asistente .accion--wa {
    background: var(--papel);
    color: var(--pizarra);
    border-color: var(--regla);
    cursor: not-allowed;
  }

  #asistente .resultado-nota {
    font-size: 13px;
    color: var(--pizarra);
    margin: calc(var(--espacio) * 2) 0 0;
  }

  #asistente .resultado-reiniciar {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--espacio) * 0.5);
    margin-top: calc(var(--espacio) * 3);
    background: none;
    border: none;
    padding: var(--espacio) 0;
    font-family: var(--fuente-datos);
    font-size: 13px;
    color: var(--pizarra);
    cursor: pointer;
  }
  #asistente .resultado-reiniciar:hover { color: var(--tinta); }
  #asistente .resultado-reiniciar:focus-visible { outline: 2px solid var(--oro); outline-offset: 2px; }

  /* Entrada sutil de cada paso */
  #asistente .paso-anim { animation: asistente-paso 0.3s ease both; }
  @keyframes asistente-paso {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    #asistente .paso-anim { animation: none; }
    #asistente .opcion, #asistente .opcion-flecha { transition: none; }
  }
</style>

<script>
  type Area = "contabilidad" | "auditoria" | "asesoria" | "legal";
  interface Opcion { label: string; next?: string; area?: Area }
  interface Nodo { pregunta: string; opciones: Opcion[] }
  interface Encargada { area: string; nombre: string; primer: string; correo: string }
  interface AsistenteDatos {
    pasoLabel: string;
    volver: string;
    reiniciar: string;
    arbol: Record<string, Nodo>;
    encargadas: Record<Area, Encargada>;
    resultado: {
      tituloPre: string; tituloPost: string;
      encargadaPre: string; encargadaPost: string;
      correoBtn: string; waBtn: string; waTitle: string;
      notaPre: string; notaPost: string;
      asunto: string; saludo: string; cuerpoIntro: string;
      loQueBusco: string; miConsulta: string;
    };
  }

  // Plantilla simple: reemplaza {clave} por su valor.
  const fmt = (s: string, vars: Record<string, string>) =>
    s.replace(/\{(\w+)\}/g, (_, k) => vars[k] ?? `{${k}}`);

  const datosEl = document.getElementById("asistente-datos");
  const cuerpo = document.getElementById("asistente-cuerpo");
  if (datosEl && cuerpo) {
    const D = JSON.parse(datosEl.textContent || "{}") as AsistenteDatos;
    const ARBOL = D.arbol;
    const ENCARGADAS = D.encargadas;
    const R = D.resultado;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const historial: { nodeId: string; label: string }[] = [];

    const esc = (s: string) =>
      s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");

    function enfocar(sel: string) {
      cuerpo!.querySelector<HTMLElement>(sel)?.focus();
    }

    function renderNodo(nodeId: string) {
      const nodo = ARBOL[nodeId];
      if (!nodo) return;
      const paso = historial.length + 1;
      const opciones = nodo.opciones
        .map((op) => {
          const attr = op.area ? `data-area="${op.area}"` : `data-next="${esc(op.next!)}"`;
          return `<button type="button" class="opcion" ${attr} data-label="${esc(op.label)}">
            <span>${esc(op.label)}</span>
            <span class="opcion-flecha" aria-hidden="true">→</span>
          </button>`;
        })
        .join("");
      const volver = historial.length
        ? `<button type="button" class="paso-volver" data-volver><span aria-hidden="true">‹</span> ${esc(D.volver)}</button>`
        : "";
      cuerpo!.innerHTML = `
        <div class="paso${reduce ? "" : " paso-anim"}">
          <p class="paso-progreso">${esc(D.pasoLabel)} ${paso}</p>
          <h3 class="paso-pregunta" tabindex="-1">${esc(nodo.pregunta)}</h3>
          <div class="opciones" data-nodo="${esc(nodeId)}">${opciones}</div>
          ${volver}
        </div>`;
      enfocar(".paso-pregunta");
    }

    function renderResultado(area: Area) {
      const e = ENCARGADAS[area];
      const resumen = historial.map((h) => h.label).join(" › ") || e.area;
      const asunto = fmt(R.asunto, { area: e.area });
      const cuerpoCorreo =
        `${fmt(R.saludo, { primer: e.primer })}\n\n` +
        `${R.cuerpoIntro}\n\n` +
        `${fmt(R.loQueBusco, { resumen })}\n\n` +
        `${R.miConsulta}\n`;
      const mailto = `mailto:${e.correo}?subject=${encodeURIComponent(asunto)}&body=${encodeURIComponent(cuerpoCorreo)}`;
      cuerpo!.innerHTML = `
        <div class="resultado${reduce ? "" : " paso-anim"}">
          <p class="resultado-area">${esc(e.area)}</p>
          <h3 class="resultado-titulo" tabindex="-1">${esc(R.tituloPre)}<strong>${esc(e.area)}</strong>${esc(R.tituloPost)}</h3>
          <p class="resultado-encargada">${esc(R.encargadaPre)}<span class="nombre">${esc(e.nombre)}</span>${esc(R.encargadaPost)}</p>
          <div class="resultado-acciones">
            <a class="accion accion--correo" href="${mailto}">
              <span aria-hidden="true">✉</span> ${esc(fmt(R.correoBtn, { primer: e.primer }))}
            </a>
            <!-- TODO: activar cuando el cliente proporcione el WhatsApp Business
                 (usar https://wa.me/<numero>?text=<resumen prellenado>) -->
            <button type="button" class="accion accion--wa" disabled aria-disabled="true" title="${esc(R.waTitle)}">
              <span aria-hidden="true">●</span> ${esc(R.waBtn)}
            </button>
          </div>
          <p class="resultado-nota">${esc(R.notaPre)}<strong>${esc(e.correo)}</strong>${esc(R.notaPost)}</p>
          <button type="button" class="resultado-reiniciar" data-reiniciar><span aria-hidden="true">↺</span> ${esc(D.reiniciar)}</button>
        </div>`;
      enfocar(".resultado-titulo");
    }

    cuerpo.addEventListener("click", (ev) => {
      const t = (ev.target as HTMLElement).closest("button, a");
      if (!t) return;
      if (t.matches(".opcion")) {
        const el = t as HTMLElement;
        const label = el.dataset.label || "";
        const nodoId = (el.closest(".opciones") as HTMLElement)?.dataset.nodo || "inicio";
        if (el.dataset.area) {
          historial.push({ nodeId: nodoId, label });
          renderResultado(el.dataset.area as Area);
        } else if (el.dataset.next) {
          historial.push({ nodeId: nodoId, label });
          renderNodo(el.dataset.next);
        }
      } else if (t.matches("[data-volver]")) {
        const ant = historial.pop();
        renderNodo(ant ? ant.nodeId : "inicio");
      } else if (t.matches("[data-reiniciar]")) {
        historial.length = 0;
        renderNodo("inicio");
      }
    });

    renderNodo("inicio");
  }
</script>
