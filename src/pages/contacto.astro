---
import Base from "@layouts/Base.astro";

const telefonos = [
  { num: "444-833-40-98", tel: "+524448334098" },
  { num: "444-833-40-99", tel: "+524448334099" },
  { num: "444-211-60-00", tel: "+524442116000" },
];

// Embed corregido (el original tenía la URL malformada con saltos de línea)
const mapaSrc =
  "https://www.google.com/maps?q=Calle+Francisco+Pe%C3%B1a+245,+Las+%C3%81guilas+3ra+Secci%C3%B3n,+San+Luis+Potos%C3%AD,+S.L.P.&output=embed";
---

<Base
  title="Contacto — Ramírez Medellín, S.C."
  description="Contáctenos: Calle Francisco Peña 245, Las Águilas 3ra Sección, San Luis Potosí. Teléfonos 444-833-40-98, 444-833-40-99 y 444-211-60-00. despacho@rmp.mx"
>

  <!-- ═══════════════════════════════ HERO ═══ -->
  <section class="phero fondo-oscuro">
    <div class="phero-lineas" aria-hidden="true"></div>
    <div class="contenedor phero-inner">
      <p class="eyebrow phero-anim-1">
        <span class="eyebrow-linea" aria-hidden="true"></span>
        Contacto
      </p>
      <h1 class="phero-h1 phero-anim-2">
        Hablemos de<br />
        <em class="texto-oro">sus cuentas.</em>
      </h1>
      <p class="phero-sub phero-anim-3">
        Cuéntenos qué necesita su empresa y un especialista de la firma
        le responderá a la brevedad.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════ FORMULARIO + DATOS ═══ -->
  <section class="contacto" aria-label="Formulario y datos de contacto">
    <div class="contenedor">
      <div class="contacto-grid">

        <!-- Formulario -->
        <div class="form-col revela">
          <h2 class="form-titulo">Envíenos un mensaje</h2>

          <!--
            TODO: confirmar destino del formulario con el cliente
            (correo, Formspree, Resend u otro). El hosting actual es PHP.
            Mientras tanto el action apunta a un stub.
          -->
          <form
            class="form"
            id="form-contacto"
            method="POST"
            action="#"
            novalidate
          >
            <div class="campo">
              <label for="nombre">Nombre <span class="req" aria-hidden="true">*</span></label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                aria-describedby="error-nombre"
              />
              <p class="campo-error" id="error-nombre" hidden>Escriba su nombre.</p>
            </div>

            <div class="campo-fila">
              <div class="campo">
                <label for="email">Correo electrónico <span class="req" aria-hidden="true">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  aria-describedby="error-email"
                />
                <p class="campo-error" id="error-email" hidden>Escriba un correo válido.</p>
              </div>

              <div class="campo">
                <label for="telefono">Teléfono</label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  autocomplete="tel"
                />
              </div>
            </div>

            <div class="campo">
              <label for="asunto">Asunto <span class="req" aria-hidden="true">*</span></label>
              <input
                type="text"
                id="asunto"
                name="asunto"
                required
                aria-describedby="error-asunto"
              />
              <p class="campo-error" id="error-asunto" hidden>Escriba el asunto.</p>
            </div>

            <div class="campo">
              <label for="mensaje">Mensaje <span class="req" aria-hidden="true">*</span></label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="6"
                required
                aria-describedby="error-mensaje"
              ></textarea>
              <p class="campo-error" id="error-mensaje" hidden>Escriba su mensaje.</p>
            </div>

            <button type="submit" class="form-enviar">Enviar mensaje</button>

            <p class="form-exito" id="form-exito" hidden>
              Gracias por su mensaje. Le responderemos a la brevedad.
            </p>

            <p class="form-aviso">
              Al enviar este formulario acepta nuestro
              <a href="/aviso-de-privacidad">aviso de privacidad</a>.
              <!-- TODO: redactar aviso de privacidad (obligatorio por LFPDPPP) -->
            </p>
          </form>
        </div>

        <!-- Datos -->
        <aside class="datos-col revela" style="--retraso: 120ms">
          <div class="dato">
            <h3 class="dato-titulo">Oficina</h3>
            <address class="dato-texto">
              Calle Francisco Peña 245<br />
              Las Águilas 3ra Sección<br />
              San Luis Potosí, S.L.P.
            </address>
          </div>

          <div class="dato">
            <h3 class="dato-titulo">Teléfonos</h3>
            <ul class="dato-lista" role="list">
              {telefonos.map(({ num, tel }) => (
                <li><a href={`tel:${tel}`} class="dato-mono">{num}</a></li>
              ))}
            </ul>
          </div>

          <div class="dato">
            <h3 class="dato-titulo">Correo</h3>
            <a href="mailto:despacho@rmp.mx" class="dato-mono">despacho@rmp.mx</a>
          </div>

          <div class="dato">
            <h3 class="dato-titulo">Horario</h3>
            <p class="dato-texto">
              <!-- TODO: confirmar horario de oficina con el cliente -->
              Lunes a viernes
            </p>
          </div>

          <div class="dato">
            <h3 class="dato-titulo">Portal de clientes</h3>
            <a
              href="https://rmp.abaconsulting.mx/login"
              class="dato-portal"
              target="_blank"
              rel="noopener noreferrer"
            >
              rmp.abaconsulting.mx →
            </a>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ MAPA ═══ -->
  <section class="mapa revela" aria-label="Ubicación en el mapa">
    <iframe
      src={mapaSrc}
      title="Mapa: Calle Francisco Peña 245, Las Águilas 3ra Sección, San Luis Potosí"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </section>

</Base>

<style>
  /* ═══════ Utilidades ═══════ */
  .contenedor {
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding-inline: calc(var(--espacio) * 3);
  }

  .eyebrow {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2.5);
  }

  .eyebrow-linea {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--oro);
    vertical-align: middle;
    margin-inline-end: calc(var(--espacio) * 1.5);
  }

  .texto-oro { color: var(--oro); font-style: italic; }

  .revela {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--retraso, 0ms),
                transform 0.6s ease var(--retraso, 0ms);
  }
  .revela.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .revela { opacity: 1; transform: none; transition: none; }
  }

  /* ═══════ HERO ═══════ */
  .phero {
    position: relative;
    background-color: var(--tinta);
    background-image: radial-gradient(
      ellipse 90% 70% at 30% 10%,
      rgb(26 53 101 / 0.5),
      transparent 60%
    );
    overflow: hidden;
  }

  .phero-lineas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 47px,
      rgb(216 210 196 / 0.07) 47px,
      rgb(216 210 196 / 0.07) 48px
    );
    mask-image: linear-gradient(to bottom, transparent, black 20%);
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    padding-block: calc(64px + var(--espacio) * 10) calc(var(--espacio) * 10);
  }

  .phero-h1 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(44px, 6.5vw, 92px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 3);
  }

  .phero-sub {
    font-size: clamp(16px, 1.6vw, 18px);
    line-height: 1.7;
    color: rgb(250 247 240 / 0.6);
    max-width: 520px;
  }

  .phero-anim-1 { animation: sube 0.5s ease 0.1s both; }
  .phero-anim-2 { animation: sube 0.6s ease 0.25s both; }
  .phero-anim-3 { animation: sube 0.5s ease 0.4s both; }

  @keyframes sube {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .phero-anim-1, .phero-anim-2, .phero-anim-3 { animation: none; }
  }

  /* ═══════ CONTACTO ═══════ */
  .contacto { padding-block: calc(var(--espacio) * 12); }

  .contacto-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: calc(var(--espacio) * 10);
    align-items: start;
  }

  /* ── Formulario ── */
  .form-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(26px, 3vw, 36px);
    letter-spacing: -0.01em;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 4);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 3);
  }

  .campo {
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 0.75);
    flex: 1;
  }

  .campo-fila {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(var(--espacio) * 3);
  }

  .campo label {
    font-family: var(--fuente-texto);
    font-size: 14px;
    font-weight: 500;
    color: var(--tinta);
  }

  .req { color: var(--oro); }

  .campo input,
  .campo textarea {
    font-family: var(--fuente-texto);
    font-size: 16px;
    color: var(--tinta);
    background: var(--blanco);
    border: 1px solid var(--regla);
    border-radius: var(--radio);
    padding: calc(var(--espacio) * 1.5) calc(var(--espacio) * 2);
    width: 100%;
    transition: border-color 0.15s ease;
  }

  .campo textarea { resize: vertical; min-height: 140px; }

  .campo input:hover,
  .campo textarea:hover { border-color: var(--pizarra); }

  .campo input:focus-visible,
  .campo textarea:focus-visible {
    outline: 2px solid var(--oro);
    outline-offset: 0;
    border-color: var(--oro);
  }

  .campo input.invalido,
  .campo textarea.invalido { border-color: var(--error); }

  .campo-error {
    font-size: 13px;
    color: var(--error);
    margin: 0;
  }

  .form-enviar {
    align-self: flex-start;
    font-family: var(--fuente-texto);
    font-size: 15px;
    font-weight: 700;
    color: var(--tinta);
    background: var(--oro);
    border: 1px solid var(--oro);
    border-radius: var(--radio);
    padding: calc(var(--espacio) * 1.5) calc(var(--espacio) * 4);
    min-height: 44px;
    cursor: pointer;
    transition: filter 0.15s ease;
  }

  .form-enviar:hover { filter: brightness(0.9); }

  .form-exito {
    font-size: 15px;
    font-weight: 500;
    color: var(--exito);
    background: rgb(47 107 79 / 0.08);
    border: 1px solid rgb(47 107 79 / 0.25);
    border-radius: var(--radio);
    padding: calc(var(--espacio) * 2);
    margin: 0;
  }

  .form-aviso {
    font-size: 13px;
    color: var(--pizarra);
    margin: 0;
  }

  .form-aviso a { color: var(--oro); }

  /* ── Datos ── */
  .datos-col {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--oro);
    position: relative;
    padding-top: calc(var(--espacio) * 4);
  }

  .datos-col::before {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--oro);
  }

  .dato {
    padding-block: calc(var(--espacio) * 3);
    border-bottom: 1px solid var(--regla);
  }

  .dato:last-child { border-bottom: none; }

  .dato-titulo {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin: 0 0 calc(var(--espacio) * 1.5);
  }

  .dato-texto {
    font-style: normal;
    font-size: 16px;
    line-height: 1.7;
    color: var(--tinta);
  }

  .dato-lista {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 0.75);
  }

  .dato-mono {
    font-family: var(--fuente-datos);
    font-size: 15px;
    color: var(--tinta);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .dato-mono:hover { color: var(--oro); }

  .dato-portal {
    font-family: var(--fuente-datos);
    font-size: 14px;
    font-weight: 500;
    color: var(--oro);
    text-decoration: none;
  }

  .dato-portal:hover { text-decoration: underline; }

  /* ═══════ MAPA ═══════ */
  .mapa {
    border-top: 1px solid var(--regla);
    line-height: 0;
  }

  .mapa iframe {
    width: 100%;
    height: clamp(320px, 45vh, 480px);
    border: 0;
    filter: grayscale(0.85) contrast(1.04);
    transition: filter 0.4s ease;
  }

  .mapa iframe:hover { filter: none; }

  @media (prefers-reduced-motion: reduce) {
    .mapa iframe { transition: none; }
  }

  /* ═══════ Responsive ═══════ */
  @media (max-width: 1023px) {
    .contacto-grid {
      grid-template-columns: 1fr;
      gap: calc(var(--espacio) * 8);
    }
  }

  @media (max-width: 767px) {
    .contenedor { padding-inline: calc(var(--espacio) * 2); }

    .campo-fila { grid-template-columns: 1fr; gap: calc(var(--espacio) * 3); }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ── Reveals ── */
  const revelables = document.querySelectorAll(".revela");
  if (reduceMotion) {
    revelables.forEach((el) => el.classList.add("visible"));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: "0px 0px -30px 0px" }
    );
    revelables.forEach((el) => io.observe(el));
  }

  /* ── Validación del formulario (stub) ──
     TODO: conectar al destino real cuando el cliente lo confirme. */
  const form = document.getElementById("form-contacto") as HTMLFormElement | null;
  const exito = document.getElementById("form-exito");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    let valido = true;
    const campos = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
      "input[required], textarea[required]"
    );

    for (const campo of campos) {
      const error = document.getElementById(`error-${campo.id}`);
      const esInvalido =
        campo.value.trim() === "" ||
        (campo.type === "email" && !campo.checkValidity());

      campo.classList.toggle("invalido", esInvalido);
      if (error) error.hidden = !esInvalido;
      if (esInvalido) valido = false;
    }

    if (valido && exito) {
      exito.hidden = false;
      form.reset();
      exito.scrollIntoView({ behavior: reduceMotion ? "auto" : "smooth", block: "nearest" });
    }
  });
</script>
