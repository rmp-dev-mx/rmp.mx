---
import Base from "@layouts/Base.astro";
import Boton from "@components/Boton.astro";
import LogoMarca from "@components/LogoMarca.astro";

const servicios = [
  {
    folio: "01",
    titulo: "Contabilidad",
    id: "contabilidad",
    desc: "Registros contables, estados financieros, declaraciones de impuestos y determinación de nóminas.",
  },
  {
    folio: "02",
    titulo: "Auditoría",
    id: "auditoria",
    desc: "Dictamen de estados financieros, cumplimiento fiscal, seguridad social y auditoría gubernamental.",
  },
  {
    folio: "03",
    titulo: "Asesoría de Negocios",
    id: "asesoria",
    desc: "Consultoría, planeación patrimonial, mediación de conflictos y evaluación de desempeño.",
  },
  {
    folio: "04",
    titulo: "Legal",
    id: "legal",
    desc: "Defensa fiscal, asesoría empresarial, consultoría laboral, fusiones, escisiones y due diligence.",
  },
];

const stats = [
  { cifra: "1998", label: "Año de fundación" },
  { cifra: "28", label: "Años de trayectoria" },
  { cifra: "4", label: "Áreas de práctica" },
  { cifra: "CONTPAQi", label: "Distribuidor Asociado" },
];
---

<Base
  title="Ramírez Medellín, S.C. — Contadores Públicos y Abogados en San Luis Potosí"
  description="Firma de Contadores Públicos y Abogados fundada en 1998 en San Luis Potosí. Especialistas en contabilidad, auditoría, asesoría de negocios y derecho empresarial."
>

  <!-- ══════════════════════════════════════════ HERO ══ -->
  <section class="hero fondo-oscuro">
    <div class="hero-inner">

      <!-- Columna de texto -->
      <div class="hero-texto">
        <p class="hero-eyebrow">San Luis Potosí · desde 1998</p>
        <!-- TODO: confirmar titular definitivo con el cliente -->
        <h1 class="hero-h1">
          Veintiocho<br />
          años llevando<br />
          las cuentas<br />
          claras
        </h1>
        <p class="hero-sub">
          Contabilidad · Auditoría<br />
          Asesoría de Negocios · Legal
        </p>
        <div class="hero-ctas">
          <Boton href="/contacto" variant="primario">Agenda una consulta</Boton>
          <a
            href="https://rmp.abaconsulting.mx/login"
            class="hero-link-portal"
            target="_blank"
            rel="noopener noreferrer"
          >
            Portal de clientes →
          </a>
        </div>
      </div>

      <!-- Columna de marca (decorativa) -->
      <div class="hero-marca" aria-hidden="true">
        <LogoMarca class="hero-logo" />
      </div>

    </div>

    <!-- Líneas del libro mayor animadas -->
    <div class="hero-lineas" aria-hidden="true"></div>
  </section>

  <!-- ═════════════════════════════════════════ STATS ══ -->
  <section class="stats fondo-oscuro" aria-label="Cifras de la firma">
    <div class="contenedor">
      <div class="stats-divisor" aria-hidden="true"></div>
      <ul class="stats-lista" role="list">
        {stats.map(({ cifra, label }) => (
          <li class="stats-item">
            <span class="stats-cifra">{cifra}</span>
            <span class="stats-label">{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════ SERVICIOS ══ -->
  <section class="servicios" aria-labelledby="servicios-titulo">
    <div class="contenedor">
      <header class="servicios-header">
        <div class="servicios-header-texto">
          <p class="eyebrow eyebrow--oscuro">Nuestros servicios</p>
          <h2 id="servicios-titulo">Cuatro áreas<br />de práctica</h2>
        </div>
        <p class="servicios-header-desc">
          Prestamos servicios a todo tipo de personas y entidades del sector
          público y privado, nacionales y extranjeras, con experiencia en
          actividades económicas diversas.
        </p>
      </header>

      <ul class="servicios-grid" role="list">
        {servicios.map(({ folio, titulo, id, desc }) => (
          <li>
            <article class="servicio-card">
              <span class="servicio-folio" aria-hidden="true">{folio}</span>
              <div class="servicio-cuerpo">
                <h3 class="servicio-titulo">{titulo}</h3>
                <p class="servicio-desc">{desc}</p>
              </div>
              <a
                href={`/servicios#${id}`}
                class="servicio-link"
                aria-label={`Ver servicios de ${titulo}`}
              >
                <span>Ver detalle</span>
                <span class="servicio-link-arrow" aria-hidden="true">→</span>
              </a>
            </article>
          </li>
        ))}
      </ul>

      <div class="servicios-pie">
        <Boton href="/servicios" variant="secundario">Todos los servicios</Boton>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════ BOLETÍN ══ -->
  <section class="boletin fondo-oscuro" aria-labelledby="boletin-titulo">
    <div class="contenedor">
      <div class="boletin-grid">
        <div class="boletin-contenido">
          <p class="eyebrow">Boletín Resiliencia</p>
          <h2 id="boletin-titulo" class="boletin-titulo">
            Información fiscal<br />oportuna
          </h2>
          <p class="boletin-desc">
            Una colaboración de todos los que integramos esta firma con el
            objetivo de comunicarle de forma oportuna aquellos
            acontecimientos relevantes que nos afectan a todos,
            contribuyendo a facilitar la adaptación a los cambios
            legales y fiscales.
          </p>
          <div class="boletin-ctas">
            <Boton
              href="/Boletin/web/publicacion/2026/enero.html"
              variant="primario"
              target="_blank"
              rel="noopener noreferrer"
            >
              Publicación enero 2026
            </Boton>
            <Boton href="/boletin" variant="secundario">Ver historial</Boton>
          </div>
        </div>
        <div class="boletin-deco" aria-hidden="true">
          <span class="boletin-deco-num">2026</span>
          <span class="boletin-deco-mes">Enero</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════ FILOSOFÍA ══ -->
  <section class="filosofia" aria-label="Filosofía de la firma">
    <div class="contenedor">
      <div class="filosofia-inner">
        <span class="filosofia-comilla" aria-hidden="true">❝</span>
        <blockquote class="filosofia-cita">
          Somos un grupo de profesionales especializados en asesoría
          patrimonial en constante actualización, comprometidos a prestar
          un servicio de la más alta calidad a nivel nacional e
          internacional utilizando la mejor de las herramientas
          disponibles con base en la creatividad e innovación de nuestro
          personal.
        </blockquote>
      </div>
      <div class="filosofia-divisor" aria-hidden="true"></div>
      <div class="filosofia-pie">
        <p class="filosofia-firma">Ramírez Medellín, S.C. — San Luis Potosí, 1998</p>
        <Boton href="/nosotros" variant="secundario">Conoce la firma</Boton>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════ CTA CONTACTO ══ -->
  <section class="cta fondo-oscuro" aria-label="Contacto">
    <div class="contenedor">
      <div class="cta-divisor" aria-hidden="true"></div>
      <div class="cta-inner">
        <div class="cta-texto">
          <p class="eyebrow">Hablemos</p>
          <h2 class="cta-titulo">¿Listo para ordenar<br />sus finanzas?</h2>
          <address class="cta-datos">
            <a href="tel:+524448334098">444-833-40-98</a>
            <span aria-hidden="true">·</span>
            <a href="tel:+524448334099">444-833-40-99</a>
            <br />
            <a href="mailto:despacho@rmp.mx">despacho@rmp.mx</a>
          </address>
        </div>
        <div class="cta-accion">
          <Boton href="/contacto" variant="primario">Agenda una consulta</Boton>
          <p class="cta-dirección">
            Calle Francisco Peña 245<br />Las Águilas 3ra Sección<br />
            San Luis Potosí, S.L.P.
          </p>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════ Utilidades ═══════ */
  .contenedor {
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding-inline: calc(var(--espacio) * 3);
  }

  .eyebrow {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2.5);
  }

  .eyebrow--oscuro { /* --oro funciona en ambos fondos */ }

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    background-color: var(--tinta);
    min-height: 100dvh;
    min-height: 100vh;
    display: flex;
    align-items: stretch;
    overflow: hidden;
  }

  /* Rayado del libro mayor */
  .hero-lineas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 39px,
      rgb(216 210 196 / 0.09) 39px,
      rgb(216 210 196 / 0.09) 40px
    );
    animation: lineas-in 1.2s ease both;
  }

  @keyframes lineas-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-lineas { animation: none; }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 42%;
    width: 100%;
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding: calc(64px + var(--espacio) * 12) calc(var(--espacio) * 3) calc(var(--espacio) * 12);
    gap: calc(var(--espacio) * 4);
    align-items: center;
  }

  /* Texto del hero */
  .hero-eyebrow {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 3);
    animation: sube 0.5s ease 0.1s both;
  }

  .hero-h1 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(48px, 5.5vw, 84px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 4);
    animation: sube 0.6s ease 0.25s both;
  }

  .hero-sub {
    font-family: var(--fuente-datos);
    font-size: 14px;
    color: rgb(250 247 240 / 0.45);
    letter-spacing: 0.04em;
    line-height: 2;
    margin-bottom: calc(var(--espacio) * 6);
    animation: sube 0.5s ease 0.45s both;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 3);
    animation: sube 0.5s ease 0.6s both;
  }

  .hero-link-portal {
    font-family: var(--fuente-datos);
    font-size: 13px;
    font-weight: 500;
    color: rgb(250 247 240 / 0.55);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }

  .hero-link-portal:hover { color: var(--oro); }

  @keyframes sube {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-h1,
    .hero-sub,
    .hero-ctas { animation: none; }
  }

  /* Marca decorativa */
  .hero-marca {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-logo {
    width: 90%;
    max-width: 380px;
    height: auto;
    opacity: 0.06;
    /* Los colores los hereda de las variables del fondo-oscuro / tinta */
    --lm-azul: var(--papel);
    --lm-gris: var(--papel);
  }

  /* ═══════ STATS ═══════ */
  .stats {
    background-color: var(--tinta);
    padding-bottom: calc(var(--espacio) * 10);
  }

  .stats-divisor {
    border: 0;
    border-top: 1px solid var(--oro);
    position: relative;
    margin-bottom: calc(var(--espacio) * 7);
  }
  .stats-divisor::after {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--oro);
  }

  .stats-lista {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    list-style: none;
  }

  .stats-item {
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 1.25);
    padding: calc(var(--espacio) * 3) calc(var(--espacio) * 4);
    border-inline-start: 1px solid rgb(216 210 196 / 0.12);
  }

  .stats-item:first-child { border-inline-start: none; padding-inline-start: 0; }

  .stats-cifra {
    font-family: var(--fuente-datos);
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 500;
    color: var(--papel);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stats-label {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(250 247 240 / 0.38);
  }

  /* ═══════ SERVICIOS ═══════ */
  .servicios {
    padding-block: calc(var(--espacio) * 14);
  }

  .servicios-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(var(--espacio) * 6);
    align-items: end;
    margin-bottom: calc(var(--espacio) * 8);
    padding-bottom: calc(var(--espacio) * 6);
    border-bottom: 1px solid var(--regla);
  }

  .servicios-header h2 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--tinta);
    margin: 0;
  }

  .servicios-header-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--pizarra);
    max-width: 420px;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--regla);
    list-style: none;
    margin-bottom: calc(var(--espacio) * 8);
  }

  /* ── Tarjeta de servicio ── */
  .servicio-card {
    background: var(--papel);
    padding: calc(var(--espacio) * 5);
    display: flex;
    flex-direction: column;
    min-height: 340px;
    position: relative;
    transition: background 0.35s ease;
    cursor: default;
  }

  .servicio-card:hover { background: var(--tinta); }

  .servicio-folio {
    font-family: var(--fuente-datos);
    font-size: clamp(56px, 7vw, 80px);
    font-weight: 500;
    line-height: 1;
    color: var(--regla);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
    transition: color 0.35s ease;
    flex-shrink: 0;
  }

  .servicio-card:hover .servicio-folio {
    color: rgb(250 247 240 / 0.06);
  }

  .servicio-cuerpo {
    margin-top: auto;
    padding-top: calc(var(--espacio) * 3);
  }

  .servicio-titulo {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 24px;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 1.5);
    transition: color 0.35s ease;
  }

  .servicio-card:hover .servicio-titulo { color: var(--papel); }

  .servicio-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--pizarra);
    margin: 0 0 calc(var(--espacio) * 3);
    transition: color 0.35s ease;
  }

  .servicio-card:hover .servicio-desc { color: rgb(250 247 240 / 0.55); }

  .servicio-link {
    display: inline-flex;
    align-items: center;
    gap: var(--espacio);
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oro);
    text-decoration: none;
    align-self: flex-start;
  }

  .servicio-link-arrow {
    transition: transform 0.2s ease;
  }

  .servicio-link:hover .servicio-link-arrow { transform: translateX(4px); }

  @media (prefers-reduced-motion: reduce) {
    .servicio-card { transition: none; }
    .servicio-folio,
    .servicio-titulo,
    .servicio-desc { transition: none; }
    .servicio-link-arrow { transition: none; }
  }

  .servicios-pie { text-align: center; }

  /* ═══════ BOLETÍN ═══════ */
  .boletin {
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 14);
    overflow: hidden;
  }

  .boletin-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: calc(var(--espacio) * 6);
    align-items: center;
  }

  .boletin-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--papel);
    margin-block: calc(var(--espacio) * 2) calc(var(--espacio) * 3);
  }

  .boletin-desc {
    font-size: 15px;
    line-height: 1.75;
    color: rgb(250 247 240 / 0.6);
    margin-bottom: calc(var(--espacio) * 5);
    max-width: 520px;
  }

  .boletin-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 1.5);
  }

  .boletin-deco {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    opacity: 0.07;
    user-select: none;
    pointer-events: none;
    flex-shrink: 0;
  }

  .boletin-deco-num {
    font-family: var(--fuente-datos);
    font-size: clamp(72px, 10vw, 120px);
    font-weight: 500;
    color: var(--papel);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .boletin-deco-mes {
    font-family: var(--fuente-datos);
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--papel);
  }

  /* ═══════ FILOSOFÍA ═══════ */
  .filosofia {
    padding-block: calc(var(--espacio) * 14);
    overflow: hidden;
  }

  .filosofia-inner {
    position: relative;
    padding-block: calc(var(--espacio) * 6);
    border-top: 1px solid var(--regla);
    border-bottom: 1px solid var(--regla);
    margin-bottom: calc(var(--espacio) * 6);
  }

  .filosofia-inner::before {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--regla);
  }
  .filosofia-inner::after {
    content: "";
    position: absolute;
    inset: auto 0 -4px 0;
    border-bottom: 1px solid var(--regla);
  }

  .filosofia-comilla {
    display: block;
    font-family: var(--fuente-display);
    font-size: clamp(56px, 8vw, 96px);
    line-height: 0.8;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 3);
    user-select: none;
  }

  .filosofia-cita {
    font-family: var(--fuente-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(20px, 2.8vw, 34px);
    line-height: 1.5;
    color: var(--tinta);
    max-width: 900px;
    margin: 0;
    padding: 0;
  }

  .filosofia-divisor { display: none; } /* replaced by ::after on inner */

  .filosofia-pie {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 3);
  }

  .filosofia-firma {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pizarra);
  }

  /* ═══════ CTA FINAL ═══════ */
  .cta {
    background-color: var(--tinta);
    padding-bottom: calc(var(--espacio) * 14);
  }

  .cta-divisor {
    border: 0;
    border-top: 1px solid var(--oro);
    position: relative;
    margin-bottom: calc(var(--espacio) * 8);
  }
  .cta-divisor::after {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--oro);
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: calc(var(--espacio) * 8);
    align-items: start;
  }

  .cta-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--papel);
    margin-block: calc(var(--espacio) * 2) calc(var(--espacio) * 3);
  }

  .cta-datos {
    font-style: normal;
    font-family: var(--fuente-datos);
    font-size: 14px;
    line-height: 2;
    color: rgb(250 247 240 / 0.5);
  }

  .cta-datos a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .cta-datos a:hover { color: var(--oro); }

  .cta-accion {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: calc(var(--espacio) * 3);
    padding-top: calc(var(--espacio) * 2);
  }

  .cta-dirección {
    font-family: var(--fuente-datos);
    font-size: 12px;
    line-height: 1.8;
    color: rgb(250 247 240 / 0.3);
    text-align: right;
  }

  /* ═══════ Responsive ═══════ */
  @media (max-width: 1023px) {
    .hero-inner {
      grid-template-columns: 1fr;
