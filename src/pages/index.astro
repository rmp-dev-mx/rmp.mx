---
import Base from "@layouts/Base.astro";
import Boton from "@components/Boton.astro";

const servicios = [
  {
    folio: "01",
    titulo: "Contabilidad",
    id: "contabilidad",
    desc: "Planeación, registros contables, estados financieros, declaraciones de impuestos y determinación de nóminas.",
  },
  {
    folio: "02",
    titulo: "Auditoría",
    id: "auditoria",
    desc: "Dictamen de estados financieros, cumplimiento fiscal, seguridad social, gubernamental y propósitos específicos.",
  },
  {
    folio: "03",
    titulo: "Asesoría de Negocios",
    id: "asesoria",
    desc: "Consultoría, análisis de costos, planeación patrimonial, mediación de conflictos y evaluación de desempeño.",
  },
  {
    folio: "04",
    titulo: "Legal",
    id: "legal",
    desc: "Defensa fiscal, asesoría empresarial, consultoría laboral, fusiones, escisiones y due diligence.",
  },
];

const credenciales = [
  { cifra: "1998", etiqueta: "Año de fundación" },
  { cifra: "28", etiqueta: "Años de trayectoria" },
  { cifra: "4", etiqueta: "Áreas de práctica" },
  { cifra: "CONTPAQi", etiqueta: "Distribuidor Asociado" },
];
---

<Base
  title="Ramírez Medellín, S.C. — Contadores Públicos y Abogados en San Luis Potosí"
  description="Firma de Contadores Públicos y Abogados fundada en 1998 en San Luis Potosí. Especialistas en contabilidad, auditoría, asesoría de negocios y derecho empresarial."
>

  <!-- ══════════════════════ HERO ══════════════════════ -->
  <section class="hero fondo-oscuro">
    <div class="contenedor">
      <p class="eyebrow">Ramírez Medellín, S.C.</p>
      <!-- TODO: confirmar titular con cliente -->
      <h1 class="hero-titular">
        Veintiocho años llevando las cuentas claras de las empresas potosinas
      </h1>
      <p class="hero-areas">
        Contabilidad · Auditoría · Asesoría de Negocios · Legal
      </p>
      <div class="hero-ctas">
        <Boton href="/contacto" variant="primario">Agenda una consulta</Boton>
        <Boton
          href="https://rmp.abaconsulting.mx/login"
          variant="secundario"
          target="_blank"
          rel="noopener noreferrer"
        >
          Portal de clientes
        </Boton>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ CREDIBILIDAD ══════════════════════ -->
  <section class="credibilidad fondo-oscuro" aria-label="Cifras de la firma">
    <div class="contenedor">
      <hr class="divisor" aria-hidden="true" />
      <ul class="cred-lista" role="list">
        {credenciales.map(({ cifra, etiqueta }) => (
          <li class="cred-item">
            <span class="cred-cifra">{cifra}</span>
            <span class="cred-etiqueta">{etiqueta}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════ SERVICIOS ══════════════════════ -->
  <section class="servicios" aria-labelledby="servicios-titulo">
    <div class="contenedor">
      <header class="seccion-header">
        <p class="eyebrow eyebrow--tinta">Nuestros servicios</p>
        <h2 id="servicios-titulo">
          Cuatro áreas de práctica<br />al servicio de su empresa
        </h2>
      </header>

      <ul class="servicios-grid" role="list">
        {servicios.map(({ folio, titulo, id, desc }) => (
          <li>
            <article class="servicio-tarjeta">
              <p class="servicio-folio">{folio}</p>
              <h3 class="servicio-titulo">{titulo}</h3>
              <p class="servicio-desc">{desc}</p>
              <a
                href={`/servicios#${id}`}
                class="servicio-link"
                aria-label={`Ver servicios de ${titulo}`}
              >
                Ver detalle →
              </a>
            </article>
          </li>
        ))}
      </ul>

      <div class="servicios-pie">
        <Boton href="/servicios" variant="secundario">Todos los servicios</Boton>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ BOLETÍN ══════════════════════ -->
  <section class="boletin fondo-oscuro" aria-labelledby="boletin-titulo">
    <div class="contenedor">
      <div class="boletin-inner">
        <div class="boletin-contenido">
          <p class="eyebrow">Boletín Resiliencia</p>
          <h2 id="boletin-titulo" class="boletin-titulo">
            Información fiscal oportuna<br />para su empresa
          </h2>
          <p class="boletin-desc">
            Una colaboración de todos los que integramos esta firma con el
            objetivo de comunicarle de forma oportuna aquellos
            acontecimientos relevantes que nos afectan a todos,
            contribuyendo a facilitar la adaptación a los cambios
            legales-fiscales.
          </p>
          <div class="boletin-ctas">
            <Boton
              href="/Boletin/web/publicacion/2026/enero.html"
              variant="primario"
              target="_blank"
              rel="noopener noreferrer"
            >
              Publicación vigente
            </Boton>
            <Boton href="/boletin" variant="secundario">Ver historial</Boton>
          </div>
        </div>
        <div class="boletin-acento" aria-hidden="true">
          <span class="boletin-num">2026</span>
          <span class="boletin-mes">Enero</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ FILOSOFÍA ══════════════════════ -->
  <section class="filosofia" aria-label="Filosofía de la firma">
    <div class="contenedor">
      <hr class="divisor divisor--claro" aria-hidden="true" />
      <blockquote class="filosofia-cita">
        "Somos un grupo de profesionales especializados en asesoría
        patrimonial en constante actualización, comprometidos a prestar
        un servicio de la más alta calidad a nivel nacional e
        internacional."
      </blockquote>
      <hr class="divisor divisor--claro" aria-hidden="true" />
      <div class="filosofia-pie">
        <p class="filosofia-firma">Ramírez Medellín, S.C. — desde 1998</p>
        <Boton href="/nosotros" variant="secundario">Conoce la firma</Boton>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ CTA FINAL ══════════════════════ -->
  <section class="cta-final fondo-oscuro" aria-label="Contacto">
    <div class="contenedor">
      <hr class="divisor" aria-hidden="true" />
      <div class="cta-final-inner">
        <div>
          <p class="eyebrow">Contáctenos</p>
          <h2 class="cta-final-titulo">¿Listo para hablar con nosotros?</h2>
          <p class="cta-final-datos">
            <a href="tel:+524448334098">444-833-40-98</a>
            <span aria-hidden="true">·</span>
            <a href="mailto:despacho@rmp.mx">despacho@rmp.mx</a>
          </p>
        </div>
        <Boton href="/contacto" variant="primario">Agenda una consulta</Boton>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ─── Contenedor y eyebrow ─── */
  .contenedor {
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding-inline: calc(var(--espacio) * 3);
  }

  .eyebrow {
    font-family: var(--fuente-datos);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2);
  }

  .eyebrow--tinta {
    /* El --oro funciona sobre ambos fondos; sin override necesario */
  }

  /* Doble línea de totales (versión página) */
  .divisor {
    border: 0;
    border-top: 1px solid var(--oro);
    position: relative;
    margin-block: calc(var(--espacio) * 5);
  }
  .divisor::after {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--oro);
  }
  .divisor--claro {
    border-color: var(--regla);
  }
  .divisor--claro::after {
    border-color: var(--regla);
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 16) calc(var(--espacio) * 10);
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 31px,
      rgb(216 210 196 / 0.07) 31px,
      rgb(216 210 196 / 0.07) 32px
    );
    animation: lineas 1s ease both;
  }

  @keyframes lineas {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero::before { animation: none; }
  }

  .hero .contenedor {
    position: relative;
    z-index: 1;
  }

  .hero-titular {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--papel);
    max-width: 760px;
    margin-block: 0 calc(var(--espacio) * 3);
    animation: fade-arriba 0.4s ease 0.15s both;
  }

  @keyframes fade-arriba {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-titular { animation: none; }
  }

  .hero-areas {
    font-family: var(--fuente-datos);
    font-size: 14px;
    color: rgb(250 247 240 / 0.55);
    letter-spacing: 0.04em;
    margin-bottom: calc(var(--espacio) * 5);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 1.5);
  }

  /* ─── CREDIBILIDAD ─── */
  .credibilidad {
    background-color: var(--tinta);
    padding-bottom: calc(var(--espacio) * 10);
  }

  .cred-lista {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: calc(var(--espacio) * 2);
    list-style: none;
  }

  .cred-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: calc(var(--espacio) * 0.75);
    text-align: center;
    padding: calc(var(--espacio) * 2);
    border-inline-start: 1px solid rgb(216 210 196 / 0.15);
  }

  .cred-item:first-child {
    border-inline-start: none;
  }

  .cred-cifra {
    font-family: var(--fuente-datos);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 500;
    color: var(--papel);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .cred-etiqueta {
    font-family: var(--fuente-datos);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(250 247 240 / 0.45);
  }

  /* ─── SERVICIOS ─── */
  .servicios {
    padding-block: calc(var(--espacio) * 12);
  }

  .seccion-header {
    margin-bottom: calc(var(--espacio) * 7);
  }

  .seccion-header h2 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(28px, 3.5vw, 36px);
    line-height: 1.2;
    color: var(--tinta);
    margin: 0;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: calc(var(--espacio) * 2.5);
    list-style: none;
    margin-bottom: calc(var(--espacio) * 6);
  }

  .servicio-tarjeta {
    background: var(--blanco);
    border: 1px solid var(--regla);
    border-radius: var(--radio);
    padding: calc(var(--espacio) * 4);
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 1.5);
    box-shadow: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .servicio-tarjeta:hover {
    box-shadow: var(--sombra);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .servicio-tarjeta { transition: none; }
    .servicio-tarjeta:hover { transform: none; box-shadow: none; }
  }

  .servicio-folio {
    font-family: var(--fuente-datos);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--oro);
    margin: 0;
  }

  .servicio-titulo {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 22px;
    color: var(--tinta);
    margin: 0;
  }

  .servicio-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--pizarra);
    margin: 0;
    flex: 1;
  }

  .servicio-link {
    font-family: var(--fuente-datos);
    font-size: 13px;
    font-weight: 500;
    color: var(--oro);
    text-decoration: none;
    letter-spacing: 0.04em;
    align-self: flex-start;
    transition: letter-spacing 0.15s ease;
  }

  .servicio-link:hover {
    letter-spacing: 0.09em;
  }

  .servicios-pie {
    text-align: center;
  }

  /* ─── BOLETÍN ─── */
  .boletin {
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 12);
  }

  .boletin-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: calc(var(--espacio) * 6);
    align-items: center;
  }

  .boletin-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.25;
    color: var(--papel);
    margin-block: calc(var(--espacio) * 1.5) calc(var(--espacio) * 2.5);
  }

  .boletin-desc {
    font-size: 15px;
    line-height: 1.7;
    color: rgb(250 247 240 / 0.65);
    margin-bottom: calc(var(--espacio) * 4);
    max-width: 540px;
  }

  .boletin-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 1.5);
  }

  .boletin-acento {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    opacity: 0.1;
    user-select: none;
    pointer-events: none;
    flex-shrink: 0;
  }

  .boletin-num {
    font-family: var(--fuente-datos);
    font-size: clamp(64px, 8vw, 96px);
    font-weight: 500;
    color: var(--papel);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .boletin-mes {
    font-family: var(--fuente-datos);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--papel);
  }

  /* ─── FILOSOFÍA ─── */
  .filosofia {
    padding-block: calc(var(--espacio) * 12);
  }

  .filosofia-cita {
    font-family: var(--fuente-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(20px, 2.5vw, 28px);
    line-height: 1.55;
    color: var(--tinta);
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    padding: 0;
  }

  .filosofia-pie {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 3);
  }

  .filosofia-firma {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pizarra);
  }

  /* ─── CTA FINAL ─── */
  .cta-final {
    background-color: var(--tinta);
    padding-bottom: calc(var(--espacio) * 12);
  }

  .cta-final-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 4);
  }

  .cta-final-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(24px, 3vw, 36px);
    color: var(--papel);
    margin-block: calc(var(--espacio) * 0.5) calc(var(--espacio) * 1.5);
  }

  .cta-final-datos {
    font-family: var(--fuente-datos);
    font-size: 14px;
    color: rgb(250 247 240 / 0.55);
    display: flex;
    flex-wrap: wrap;
    gap: var(--espacio);
    align-items: center;
  }

  .cta-final-datos a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .cta-final-datos a:hover {
    color: var(--oro);
  }

  /* ─── Responsive ─── */
  @media (max-width: 767px) {
    .contenedor {
      padding-inline: calc(var(--espacio) * 2);
    }

    .hero {
      padding-block: calc(var(--espacio) * 10) calc(var(--espacio) * 7);
    }

    .cred-lista {
      grid-template-columns: repeat(2, 1fr);
    }

    .cred-item {
      border-inline-start: none;
      border-top: 1px solid rgb(216 210 196 / 0.15);
      padding-top: calc(var(--espacio) * 2.5);
    }

    .cred-item:nth-child(-n+2) {
      border-top: none;
    }

    .servicios-grid {
      grid-template-columns: 1fr;
    }

    .boletin-inner {
      grid-template-columns: 1fr;
    }

    .boletin-acento {
      display: none;
    }

    .filosofia-cita {
      text-align: left;
    }

    .filosofia-pie,
    .cta-final-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
