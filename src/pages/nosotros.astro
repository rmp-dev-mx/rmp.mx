---
import Base from "@layouts/Base.astro";
import { url } from "../lib/url";
import Boton from "@components/Boton.astro";

const valores = [
  "Confianza",
  "Responsabilidad",
  "Respeto",
  "Creatividad",
  "Innovación",
  "Calidad",
];

const equipo = [
  {
    area: "Consultoría",
    personas: [
      {
        nombre: "Marisela Elisea Martínez",
        credencial: "C.P. por la UASLP · Especialista en Impuestos",
        correo: "marisela@rmp.mx",
      },
    ],
  },
  {
    area: "Contabilidad",
    personas: [
      {
        nombre: "Paola Guadalupe Guevara Moreno",
        credencial: "C.P. por la UASLP · Especialista en Impuestos",
        correo: "paola@rmp.mx",
      },
      {
        nombre: "Yuliana Cerda Cerda",
        credencial: "Lic. en Contador Público por la Universidad Tangamanga",
        correo: "yuliana@rmp.mx",
      },
      {
        nombre: "María Lucero Rodríguez Díaz",
        credencial: "Lic. en Contador Público por la Universidad Potosina",
        correo: "lucero.rodriguez@rmp.mx",
      },
    ],
  },
  {
    area: "Auditoría",
    personas: [
      {
        nombre: "Citlaly Reyes Jaime",
        credencial: "C.P. por la UASLP · Especialista en Auditoría",
        correo: "citlaly@rmp.mx",
      },
    ],
  },
  {
    area: "Legal",
    personas: [
      {
        nombre: "Eugenia Eloisa Navarro González",
        credencial: "Lic. en Derecho por la UASLP",
        correo: "eugenia@rmp.mx",
      },
      {
        nombre: "Alicia del Carmen Rocha Agundis",
        credencial:
          "Lic. en Derecho por la UASLP · Especialista en Justicia Administrativa (TFJA)",
        correo: "alicia.rocha@rmp.mx",
      },
    ],
  },
  {
    area: "Administración",
    personas: [
      {
        nombre: "Liliana Vega Betancourt",
        credencial: "Responsable de la Administración General de la Firma",
        correo: "liliana@rmp.mx",
      },
    ],
  },
  {
    area: "Desarrollo Humano",
    personas: [
      {
        nombre: "Gabriela Guadalupe Ramírez González",
        credencial:
          "Lic. en Psicología (Universidad Marista de SLP) · Maestrante en Psicoterapia Humanista · Experta en Desarrollo Humano y Organizacional",
        correo: "gaby@rmp.mx",
      },
    ],
  },
];

function iniciales(nombre: string): string {
  const partes = nombre.split(" ");
  return (partes[0]?.[0] ?? "") + (partes[1]?.[0] ?? "");
}
---

<Base
  title="Nosotros — Ramírez Medellín, S.C."
  description="Conozca a Ramírez Medellín, S.C.: firma de Contadores Públicos y Abogados fundada en 1998 en San Luis Potosí. Nuestra historia, valores y equipo profesional."
>

  <!-- ═══════════════════════════════ HERO ═══ -->
  <section class="phero fondo-oscuro">
    <div class="phero-lineas" aria-hidden="true"></div>
    <div class="contenedor phero-inner">
      <p class="eyebrow phero-anim-1">
        <span class="eyebrow-linea" aria-hidden="true"></span>
        Nosotros
      </p>
      <h1 class="phero-h1 phero-anim-2">
        El oficio<br />
        <em class="texto-oro">bien llevado.</em>
      </h1>
      <p class="phero-sub phero-anim-3">
        Somos una firma de Contadores Públicos y Abogados fundada en el año
        1998, en la ciudad de San Luis Potosí, México. Nos especializamos en
        prestar servicios profesionales en contabilidad, auditoría, asesoría
        de negocios, servicio legal empresarial y patrimonial.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════ HISTORIA ═══ -->
  <section class="historia" aria-labelledby="historia-titulo">
    <div class="contenedor">
      <div class="historia-grid">
        <div class="revela">
          <p class="eyebrow">Nuestra historia</p>
          <h2 id="historia-titulo" class="seccion-titulo">
            Desde 1998,<br />asiento por asiento
          </h2>
        </div>
        <div class="historia-texto revela">
          <p>
            Prestamos servicios a todo tipo de personas y entidades del
            sector público y privado, nacionales y extranjeras. Tenemos
            experiencia en atender entidades de diversas actividades
            económicas y objeto social.
          </p>
          <p>
            Contamos con una firma filial, <strong>Pacioli Asesores de
            Negocios, S.C.</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ MISIÓN / VISIÓN / VALORES ═══ -->
  <section class="mvv fondo-oscuro" aria-label="Misión, visión y valores">
    <div class="contenedor">
      <div class="doble-linea" aria-hidden="true"></div>
      <div class="mvv-grid">
        <article class="mvv-item revela">
          <p class="mvv-folio" aria-hidden="true">M</p>
          <h3 class="mvv-titulo">Misión</h3>
          <p class="mvv-texto">
            Prestar servicios de asesoría patrimonial a los clientes de una
            forma integral enfocados a optimizar sus recursos bajo un
            esquema de confianza y certidumbre.
          </p>
        </article>
        <article class="mvv-item revela" style="--retraso: 100ms">
          <p class="mvv-folio" aria-hidden="true">V</p>
          <h3 class="mvv-titulo">Visión</h3>
          <p class="mvv-texto">
            Posicionar la firma como una de las de mayor prestigio del
            centro del país.
          </p>
        </article>
        <article class="mvv-item revela" style="--retraso: 200ms">
          <p class="mvv-folio" aria-hidden="true">F</p>
          <h3 class="mvv-titulo">Filosofía</h3>
          <p class="mvv-texto">
            Profesionales en constante actualización, comprometidos a
            prestar un servicio de la más alta calidad utilizando la mejor
            de las herramientas disponibles con base en la creatividad e
            innovación de nuestro personal.
          </p>
        </article>
      </div>

      <!-- Valores como cinta de asientos -->
      <ul class="valores" role="list" aria-label="Valores">
        {valores.map((valor, i) => (
          <li class="valor revela" style={`--retraso: ${i * 70}ms`}>
            <span class="valor-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
            {valor}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════ CITA EQUIPO ═══ -->
  <section class="cita" aria-label="Cita institucional">
    <div class="contenedor">
      <div class="cita-inner revela">
        <span class="cita-comilla" aria-hidden="true">❝</span>
        <blockquote class="cita-texto">
          Reunirse en equipo es el principio, mantenerse en equipo es el
          progreso, trabajar en equipo asegura el éxito.
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ SOCIO FUNDADOR ═══ -->
  <section class="socio fondo-oscuro" aria-labelledby="socio-titulo">
    <div class="contenedor">
      <div class="socio-grid revela">
        <div class="socio-monograma" aria-hidden="true">
          <img class="socio-marca" src={url("/images/logo-rmp-emblema.webp")} alt="" width="560" height="560" decoding="async" loading="lazy" />
          <span class="socio-iniciales">JR</span>
        </div>
        <div>
          <p class="eyebrow">Socio fundador</p>
          <h2 id="socio-titulo" class="socio-nombre">
            José Cosme Ramírez Medellín
          </h2>
          <p class="socio-texto">
            Fundador de la firma en 1998 y de su filial Pacioli Asesores de
            Negocios, S.C.
            <!-- TODO: pedir al cliente semblanza, cédula profesional y fotografía del socio fundador (Socios.php está rota) -->
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ EQUIPO ═══ -->
  <section class="equipo" aria-labelledby="equipo-titulo">
    <div class="contenedor">
      <header class="equipo-header revela">
        <p class="eyebrow">Nuestro equipo</p>
        <h2 id="equipo-titulo" class="seccion-titulo">
          Quienes llevan<br />el registro
        </h2>
      </header>

      {equipo.map(({ area, personas }) => (
        <div class="equipo-area">
          <h3 class="equipo-area-titulo revela">
            <span class="equipo-area-linea" aria-hidden="true"></span>
            {area}
          </h3>
          <ul class="personas" role="list">
            {personas.map(({ nombre, credencial, correo }, i) => (
              <li class="revela" style={`--retraso: ${i * 80}ms`}>
                <article class="persona">
                  <span class="persona-monograma" aria-hidden="true">
                    {iniciales(nombre)}
                  </span>
                  <div class="persona-datos">
                    <h4 class="persona-nombre">{nombre}</h4>
                    <p class="persona-credencial">{credencial}</p>
                    <a href={`mailto:${correo}`} class="persona-correo">{correo}</a>
                  </div>
                </article>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════ PACIOLI ═══ -->
  <section class="pacioli" aria-labelledby="pacioli-titulo">
    <div class="contenedor">
      <div class="pacioli-inner revela">
        <div>
          <p class="eyebrow">Firma filial</p>
          <h2 id="pacioli-titulo" class="pacioli-titulo">
            Pacioli Asesores<br />de Negocios, S.C.
          </h2>
          <p class="pacioli-texto">
            Nuestra firma filial lleva el nombre de Luca Pacioli, padre de
            la contabilidad por partida doble.
            <!-- TODO: pedir al cliente logo vectorial y descripción de Pacioli -->
          </p>
        </div>
        <p class="pacioli-año" aria-hidden="true">1494</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ CTA ═══ -->
  <section class="cta fondo-oscuro" aria-label="Contacto">
    <div class="contenedor">
      <div class="doble-linea" aria-hidden="true"></div>
      <div class="cta-inner revela">
        <div>
          <p class="eyebrow">Hablemos</p>
          <h2 class="cta-titulo">Conozca cómo<br />podemos ayudarle</h2>
        </div>
        <div class="cta-accion">
          <Boton href={url("/contacto")} variant="primario">Agenda una consulta</Boton>
          <address class="cta-datos">
            <a href="tel:+524448334098">444-833-40-98</a>
            <span aria-hidden="true">·</span>
            <a href="mailto:despacho@rmp.mx">despacho@rmp.mx</a>
          </address>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════ Utilidades ═══════ */
  .contenedor {
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding-inline: calc(var(--espacio) * 3);
  }

  .eyebrow {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2.5);
  }

  .eyebrow-linea {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--oro);
    vertical-align: middle;
    margin-inline-end: calc(var(--espacio) * 1.5);
  }

  .texto-oro { color: var(--oro); font-style: italic; }

  .seccion-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--tinta);
    margin: 0;
  }

  .doble-linea {
    border-top: 1px solid var(--oro);
    position: relative;
    margin-bottom: calc(var(--espacio) * 8);
  }
  .doble-linea::after {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--oro);
  }


  /* ═══════ HERO ═══════ */
  .phero {
    position: relative;
    background-color: var(--tinta);
    background-image: radial-gradient(
      ellipse 90% 70% at 70% 10%,
      rgb(26 53 101 / 0.5),
      transparent 60%
    );
    overflow: hidden;
  }

  .phero-lineas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 47px,
      rgb(216 210 196 / 0.07) 47px,
      rgb(216 210 196 / 0.07) 48px
    );
    mask-image: linear-gradient(to bottom, transparent, black 20%);
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    padding-block: calc(64px + var(--espacio) * 10) calc(var(--espacio) * 12);
  }

  .phero-h1 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(44px, 6.5vw, 92px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 3);
  }

  .phero-sub {
    font-size: clamp(16px, 1.6vw, 18px);
    line-height: 1.75;
    color: rgb(250 247 240 / 0.6);
    max-width: 620px;
  }

  .phero-anim-1 { animation: sube 0.5s ease 0.1s both; }
  .phero-anim-2 { animation: sube 0.6s ease 0.25s both; }
  .phero-anim-3 { animation: sube 0.5s ease 0.4s both; }

  @keyframes sube {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .phero-anim-1, .phero-anim-2, .phero-anim-3 { animation: none; }
  }

  /* ═══════ HISTORIA ═══════ */
  .historia { padding-block: calc(var(--espacio) * 14); }

  .historia-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(var(--espacio) * 8);
    align-items: start;
  }

  .historia-texto {
    font-size: 16px;
    line-height: 1.8;
    color: var(--pizarra);
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 2.5);
    padding-top: calc(var(--espacio) * 1.5);
  }

  .historia-texto strong { color: var(--tinta); }

  /* ═══════ MVV ═══════ */
  .mvv {
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 10) calc(var(--espacio) * 12);
  }

  .mvv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: calc(var(--espacio) * 6);
    margin-bottom: calc(var(--espacio) * 10);
  }

  .mvv-folio {
    font-family: var(--fuente-display);
    font-style: italic;
    font-size: clamp(48px, 5vw, 72px);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px var(--oro);
    margin-bottom: calc(var(--espacio) * 2);
    opacity: 0.8;
  }

  .mvv-titulo {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 22px;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 1.5);
  }

  .mvv-texto {
    font-size: 15px;
    line-height: 1.7;
    color: rgb(250 247 240 / 0.6);
  }

  .valores {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--espacio) * 1.5);
  }

  .valor {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--espacio) * 1.25);
    padding: calc(var(--espacio) * 1.25) calc(var(--espacio) * 2.5);
    border: 1px solid rgb(216 210 196 / 0.2);
    border-radius: var(--radio);
    font-family: var(--fuente-texto);
    font-size: 15px;
    font-weight: 500;
    color: var(--papel);
    transition: border-color 0.2s ease;
  }

  .valor:hover { border-color: var(--oro); }

  .valor-num {
    font-family: var(--fuente-datos);
    font-size: 11px;
    color: var(--oro);
    font-variant-numeric: tabular-nums;
  }

  /* ═══════ CITA ═══════ */
  .cita { padding-block: calc(var(--espacio) * 14); }

  .cita-inner {
    position: relative;
    padding-block: calc(var(--espacio) * 6);
    border-top: 1px solid var(--regla);
    border-bottom: 1px solid var(--regla);
    text-align: center;
  }

  .cita-inner::before {
    content: "";
    position: absolute;
    inset: 3px 0 auto 0;
    border-top: 1px solid var(--regla);
  }
  .cita-inner::after {
    content: "";
    position: absolute;
    inset: auto 0 -4px 0;
    border-bottom: 1px solid var(--regla);
  }

  .cita-comilla {
    display: block;
    font-family: var(--fuente-display);
    font-size: clamp(48px, 7vw, 80px);
    line-height: 0.8;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2);
    user-select: none;
  }

  .cita-texto {
    font-family: var(--fuente-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 3vw, 36px);
    line-height: 1.45;
    color: var(--tinta);
    max-width: 880px;
    margin: 0 auto;
  }

  /* ═══════ SOCIO ═══════ */
  .socio {
    background-color: var(--tinta);
    padding-block: calc(var(--espacio) * 12);
  }

  .socio-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: calc(var(--espacio) * 6);
    align-items: center;
  }

  .socio-monograma {
    position: relative;
    width: clamp(120px, 16vw, 180px);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(216 210 196 / 0.2);
    border-radius: 50%;
  }

  .socio-marca {
    position: absolute;
    width: 70%;
    height: auto;
    opacity: 0.12;
  }

  .socio-iniciales {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: clamp(32px, 4vw, 48px);
    color: var(--oro);
  }

  .socio-nombre {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 2);
  }

  .socio-texto {
    font-size: 16px;
    line-height: 1.7;
    color: rgb(250 247 240 / 0.6);
    max-width: 540px;
  }

  /* ═══════ EQUIPO ═══════ */
  .equipo { padding-block: calc(var(--espacio) * 14); }

  .equipo-header { margin-bottom: calc(var(--espacio) * 8); }

  .equipo-area { margin-bottom: calc(var(--espacio) * 8); }

  .equipo-area-titulo {
    display: flex;
    align-items: center;
    gap: calc(var(--espacio) * 2);
    font-family: var(--fuente-datos);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin: 0 0 calc(var(--espacio) * 4);
  }

  .equipo-area-linea {
    width: 32px;
    height: 1px;
    background: var(--oro);
    flex-shrink: 0;
  }

  .personas {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: calc(var(--espacio) * 3);
  }

  .persona {
    display: flex;
    gap: calc(var(--espacio) * 2.5);
    align-items: flex-start;
    background: var(--blanco);
    border: 1px solid var(--regla);
    border-radius: var(--radio);
    padding: calc(var(--espacio) * 3);
    height: 100%;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .persona:hover {
    box-shadow: var(--sombra);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .persona { transition: none; }
    .persona:hover { transform: none; box-shadow: none; }
  }

  .persona-monograma {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    background: var(--tinta);
    color: var(--papel);
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 18px;
    border-radius: 50%;
  }

  .persona-nombre {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.25;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 0.75);
  }

  .persona-credencial {
    font-size: 13px;
    line-height: 1.55;
    color: var(--pizarra);
    margin-bottom: calc(var(--espacio) * 1.25);
  }

  .persona-correo {
    font-family: var(--fuente-datos);
    font-size: 12px;
    color: var(--oro);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .persona-correo:hover { text-decoration: underline; }

  /* ═══════ PACIOLI ═══════ */
  .pacioli {
    background: var(--blanco);
    border-block: 1px solid var(--regla);
    padding-block: calc(var(--espacio) * 12);
    overflow: hidden;
  }

  .pacioli-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: calc(var(--espacio) * 6);
    align-items: center;
  }

  .pacioli-titulo {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--tinta);
    margin: 0 0 calc(var(--espacio) * 2);
  }

