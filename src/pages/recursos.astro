---
import Base from "@layouts/Base.astro";

const recursos = [
  {
    nombre: "SAT",
    desc: "Servicio de Administración Tributaria",
    url: "https://www.sat.gob.mx",
  },
  {
    // Corregido: el sitio original enlazaba por error al SAT
    nombre: "IMSS",
    desc: "Instituto Mexicano del Seguro Social",
    url: "https://www.imss.gob.mx",
  },
  {
    nombre: "IDSE",
    desc: "IMSS desde su empresa",
    url: "https://idse.imss.gob.mx",
  },
  {
    nombre: "INFONAVIT",
    desc: "Instituto del Fondo Nacional de la Vivienda para los Trabajadores",
    url: "https://www.infonavit.org.mx",
  },
  {
    nombre: "Finanzas SLP",
    desc: "Secretaría de Finanzas de San Luis Potosí",
    url: "https://slpfinanzas.gob.mx",
  },
  {
    nombre: "OJN",
    desc: "Orden Jurídico Nacional",
    url: "http://www.ordenjuridico.gob.mx",
  },
  {
    nombre: "SCJN",
    desc: "Suprema Corte de Justicia de la Nación",
    url: "https://www.scjn.gob.mx",
  },
  {
    nombre: "DOF",
    desc: "Diario Oficial de la Federación",
    url: "https://www.dof.gob.mx",
  },
  {
    nombre: "Banxico",
    desc: "Banco de México",
    url: "https://www.banxico.org.mx",
  },
  {
    nombre: "SRE",
    desc: "Secretaría de Relaciones Exteriores",
    url: "https://www.gob.mx/sre",
  },
  {
    nombre: "SE",
    desc: "Secretaría de Economía",
    url: "https://www.gob.mx/se",
  },
  {
    nombre: "IMCP",
    desc: "Instituto Mexicano de Contadores Públicos",
    url: "https://imcp.org.mx",
  },
  {
    nombre: "CCPSLP",
    desc: "Colegio de Contadores Públicos de San Luis Potosí",
    url: "https://ccpslp.org.mx",
  },
];
---

<Base
  title="Recursos — Ramírez Medellín, S.C."
  description="Directorio de sitios oficiales de consulta frecuente: SAT, IMSS, INFONAVIT, DOF, Banxico, SCJN y más organismos fiscales y jurídicos de México."
>

  <!-- ═══════════════════════════════ HERO ═══ -->
  <section class="phero fondo-oscuro">
    <div class="phero-lineas" aria-hidden="true"></div>
    <div class="contenedor phero-inner">
      <p class="eyebrow phero-anim-1">
        <span class="eyebrow-linea" aria-hidden="true"></span>
        Recursos
      </p>
      <h1 class="phero-h1 phero-anim-2">
        Sitios<br />
        <em class="texto-oro">de interés.</em>
      </h1>
      <p class="phero-sub phero-anim-3">
        Directorio de organismos oficiales de consulta frecuente en materia
        fiscal, laboral y jurídica.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════ DIRECTORIO ═══ -->
  <section class="directorio" aria-label="Directorio de sitios oficiales">
    <div class="contenedor">
      <ul class="grid" role="list">
        {recursos.map(({ nombre, desc, url }, i) => (
          <li class="revela" style={`--retraso: ${(i % 4) * 60}ms`}>
            <a
              href={url}
              class="sitio"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="sitio-num" aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="sitio-nombre">{nombre}</span>
              <span class="sitio-desc">{desc}</span>
              <span class="sitio-flecha" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</Base>

<style>
  .contenedor {
    max-width: var(--ancho-max);
    margin: 0 auto;
    padding-inline: calc(var(--espacio) * 3);
  }

  .eyebrow {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oro);
    margin-bottom: calc(var(--espacio) * 2.5);
  }

  .eyebrow-linea {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--oro);
    vertical-align: middle;
    margin-inline-end: calc(var(--espacio) * 1.5);
  }

  .texto-oro { color: var(--oro); font-style: italic; }

  .revela {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--retraso, 0ms),
                transform 0.6s ease var(--retraso, 0ms);
  }
  .revela.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .revela { opacity: 1; transform: none; transition: none; }
  }

  /* ═══════ HERO ═══════ */
  .phero {
    position: relative;
    background-color: var(--tinta);
    background-image: radial-gradient(
      ellipse 90% 70% at 30% 10%,
      rgb(26 53 101 / 0.5),
      transparent 60%
    );
    overflow: hidden;
  }

  .phero-lineas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 47px,
      rgb(216 210 196 / 0.07) 47px,
      rgb(216 210 196 / 0.07) 48px
    );
    mask-image: linear-gradient(to bottom, transparent, black 20%);
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    padding-block: calc(64px + var(--espacio) * 10) calc(var(--espacio) * 10);
  }

  .phero-h1 {
    font-family: var(--fuente-display);
    font-weight: 500;
    font-size: clamp(44px, 6.5vw, 92px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--papel);
    margin: 0 0 calc(var(--espacio) * 3);
  }

  .phero-sub {
    font-size: clamp(16px, 1.6vw, 18px);
    line-height: 1.7;
    color: rgb(250 247 240 / 0.6);
    max-width: 520px;
  }

  .phero-anim-1 { animation: sube 0.5s ease 0.1s both; }
  .phero-anim-2 { animation: sube 0.6s ease 0.25s both; }
  .phero-anim-3 { animation: sube 0.5s ease 0.4s both; }

  @keyframes sube {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .phero-anim-1, .phero-anim-2, .phero-anim-3 { animation: none; }
  }

  /* ═══════ DIRECTORIO ═══════ */
  .directorio { padding-block: calc(var(--espacio) * 12) calc(var(--espacio) * 14); }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--regla);
    border: 1px solid var(--regla);
    list-style: none;
  }

  .sitio {
    display: flex;
    flex-direction: column;
    gap: calc(var(--espacio) * 1.25);
    background: var(--papel);
    padding: calc(var(--espacio) * 4);
    min-height: 180px;
    height: 100%;
    text-decoration: none;
    position: relative;
    transition: background 0.3s ease;
  }

  .sitio:hover { background: var(--tinta); }

  .sitio-num {
    font-family: var(--fuente-datos);
    font-size: 12px;
    font-weight: 500;
    color: var(--oro);
    font-variant-numeric: tabular-nums;
  }

  .sitio-nombre {
    font-family: var(--fuente-display);
    font-weight: 600;
    font-size: 24px;
    color: var(--tinta);
    transition: color 0.3s ease;
    margin-top: auto;
  }

  .sitio:hover .sitio-nombre { color: var(--papel); }

  .sitio-desc {
    font-size: 13px;
    line-height: 1.5;
    color: var(--pizarra);
    transition: color 0.3s ease;
  }

  .sitio:hover .sitio-desc { color: rgb(250 247 240 / 0.55); }

  .sitio-flecha {
    position: absolute;
    top: calc(var(--espacio) * 3);
    right: calc(var(--espacio) * 3);
    font-family: var(--fuente-datos);
    font-size: 16px;
    color: var(--regla);
    transition: color 0.3s ease, transform 0.25s ease;
  }

  .sitio:hover .sitio-flecha {
    color: var(--oro);
    transform: translate(3px, -3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .sitio, .sitio-nombre, .sitio-desc, .sitio-flecha { transition: none; }
  }

  /* ═══════ Responsive ═══════ */
  @media (max-width: 1023px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 767px) {
    .contenedor { padding-inline: calc(var(--espacio) * 2); }
    .grid { grid-template-columns: repeat(2, 1fr); }
    .sitio { min-height: 150px; padding: calc(var(--espacio) * 2.5); }
    .sitio-nombre { font-size: 19px; }
  }

  @media (max-width: 419px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const revelables = document.querySelectorAll(".revela");
  if (reduceMotion) {
    revelables.forEach((el) => el.classList.add("visible"));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: "0px 0px -30px 0px" }
    );
    revelables.forEach((el) => io.observe(el));
  }
</script>
