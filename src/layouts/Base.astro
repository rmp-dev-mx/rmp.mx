---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { url } from "../lib/url";
import { getLang, useTranslations, localizedUrl, getLogicalPath } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  /** true si la página tiene traducción real en el idioma activo. */
  translated?: boolean;
}
const { title, description, translated = false } = Astro.props;

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const htmlLang = lang === "en" ? "en" : "es-MX";

// Banner cuando se ve en inglés una página aún no traducida (respaldo a español).
const mostrarBannerEN = lang === "en" && !translated;

// Alternativas hreflang (misma página en cada idioma).
const rutaLogica = getLogicalPath(Astro.url.pathname);
const altEs = new URL(localizedUrl(rutaLogica, "es"), Astro.site).href;
const altEn = new URL(localizedUrl(rutaLogica, "en"), Astro.site).href;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// schema.org: la firma es a la vez despacho contable y legal
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["AccountingService", "LegalService"],
      "@id": "https://rmp.mx/#firma",
      name: "Ramírez Medellín, S.C.",
      alternateName: "Ramírez Medellín Contadores Públicos y Abogados",
      description:
        "Firma de Contadores Públicos y Abogados fundada en 1998. Contabilidad, auditoría, asesoría de negocios y servicio legal empresarial y patrimonial.",
      url: "https://rmp.mx",
      logo: "https://rmp.mx/images/logo-rmp-completo.webp",
      foundingDate: "1998",
      email: "despacho@rmp.mx",
      telephone: "+52-444-833-40-98",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Calle Francisco Peña 245, Las Águilas 3ra Sección",
        addressLocality: "San Luis Potosí",
        addressRegion: "S.L.P.",
        addressCountry: "MX",
      },
      areaServed: {
        "@type": "State",
        name: "San Luis Potosí",
      },
      sameAs: ["https://www.facebook.com/ramirezmedellinfirma"],
      knowsAbout: [
        "Contabilidad",
        "Auditoría",
        "Asesoría de negocios",
        "Defensa fiscal",
        "Derecho empresarial",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://rmp.mx/#sitio",
      url: "https://rmp.mx",
      name: "Ramírez Medellín, S.C.",
      inLanguage: "es-MX",
      publisher: { "@id": "https://rmp.mx/#firma" },
    },
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <!-- Mejora progresiva: los reveals al scroll solo aplican con JS activo -->
    <script>document.documentElement.classList.add("js");</script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={altEs} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="x-default" href={altEs} />
    <link rel="sitemap" href={url("/sitemap-index.xml")} />
    <link rel="icon" type="image/png" href={url("/favicon-96.png")} />
    <link rel="apple-touch-icon" href={url("/apple-touch-icon.png")} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === "en" ? "en_US" : "es_MX"} />
    <meta property="og:site_name" content="Ramírez Medellín, S.C." />
    <!-- TODO: generar imagen OG 1200x630 con la identidad (cuando el cliente apruebe el diseño) -->

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Fuentes: Spectral · Public Sans · IBM Plex Mono
         Carga asíncrona (media=print + onload) para no bloquear el render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Public+Sans:wght@400;500;700&family=Spectral:ital,wght@0,500;0,600;1,500&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Public+Sans:wght@400;500;700&family=Spectral:ital,wght@0,500;0,600;1,500&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <link rel="stylesheet" href={url("/styles/global.css")} />
  </head>
  <body>
    <a href="#contenido" class="skip-link">{t("skip")}</a>
    <Header />
    {mostrarBannerEN && (
      <p class="i18n-aviso" lang="en">{t("banner.enPrep")}</p>
    )}
    <main id="contenido">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .i18n-aviso {
    margin: 0;
    padding: calc(var(--espacio) * 1.25) calc(var(--espacio) * 3);
    background: var(--oro);
    color: var(--oro-contraste);
    font-family: var(--fuente-datos);
    font-size: 13px;
    text-align: center;
  }
</style>
